<%# This content will be injected into main-email-layout.ejs %>
<% locals.preheaderText = 'Your One-Time Password (OTP) for Twoem Online Productions.' %>

<h1 style="font-size: 22px; color: #0056b3; margin-bottom: 15px;">Password Reset Request</h1>
<p>Hello <strong><%= studentName || 'User' %></strong>,</p>
<p>We received a request to reset the password for your account. If you made this request, please use the verification code below to proceed.</p>

<div class="email-content-card" style="background-color: #f0f8ff; border-left: 4px solid #007bff;">
    <p style="text-align: center; font-size: 16px; margin-bottom: 10px;">Your One-Time Password (OTP) is:</p>
    <p style="text-align: center; font-size: 32px; font-weight: bold; color: #007bff; letter-spacing: 3px; margin: 10px 0;">
        <%= otp %>
    </p>
    <p style="text-align: center; font-size: 14px; color: #555;">This code expires in 10 minutes.</p>
</div>

<% if (locals.resetLink) { %>
    <p style="text-align: center; margin-top: 25px; margin-bottom: 25px;">
        Alternatively, you can reset your password by clicking the button below:
    </p>
    <p style="text-align: center;">
        <a href="<%= resetLink %>" class="button" style="background-color: #28a745; color: #ffffff !important;">Reset Password Now</a>
    </p>
<% } %>

<p style="margin-top: 25px;">If you didn't request this password reset, please ignore this email or contact us if you have security concerns. Your account is safe.</p>
<p>Best regards,<br>The Twoem Online Productions Team</p>
