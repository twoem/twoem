<!DOCTYPE html PUBLIC "-//W3C//DTD XHTML 1.0 Transitional//EN" "http://www.w3.org/TR/xhtml1/DTD/xhtml1-transitional.dtd">
<html xmlns="http://www.w3.org/1999/xhtml">
<head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Your OTP Code</title>
    <style type="text/css">
        /* Client-specific styles */
        body, table, td, a { -webkit-text-size-adjust: 100%; -ms-text-size-adjust: 100%; }
        table, td { mso-table-lspace: 0pt; mso-table-rspace: 0pt; }
        img { -ms-interpolation-mode: bicubic; border: 0; height: auto; line-height: 100%; outline: none; text-decoration: none; }

        /* General styles */
        body {
            font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
            line-height: 1.6; color: #343a40; /* Darker base text */
            margin: 0; padding: 0; background-color: #DBD4FF; /* --lavender-very-light */
        }
        .email-wrapper { width: 100%; background-color: #DBD4FF; padding: 20px 0; }
        .container {
            width: 100%; max-width: 600px; margin: 20px auto;
            background-color: #ffffff; /* White card background */
            border-radius: 12px; box-shadow: 0 4px 15px rgba(0,0,0,0.1);
            overflow: hidden; border: 1px solid #C1BFFF; /* --lavender-light-blue border */
        }
        .header {
            background-color: #C1BFFF; /* --lavender-light-blue */
            padding: 30px 20px; text-align: center;
        }
        .logo {
            max-height: 60px; /* Adjusted size */
            width: auto; display: block; margin: 0 auto 15px;
        }
        .header h1 {
            margin: 10px 0 0 0; font-size: 22px; font-weight: 600; color: #343a40;
        }
        .content { padding: 30px; font-size: 16px; line-height: 1.7; }
        .content p { margin-bottom: 18px; }
        .otp-card {
            margin: 25px 0; padding: 20px; background-color: #FDFBD4; /* --lavender-lightest-yellow */
            border-radius: 8px; text-align: center;
            border: 1px dashed #BDB96A; /* --lavender-muted-green */
        }
        .otp-card p { margin-bottom: 10px; color: var(--lavender-darker-purple, #a358d3); font-weight: 500;}
        .otp-code {
            font-size: 32px; font-weight: 700; color: #CF6DFC; /* --lavender-vibrant-purple */
            letter-spacing: 4px; display: inline-block; padding: 8px 15px;
            background-color: #fff; border-radius: 6px;
            border: 1px solid #DBD4FF; /* --lavender-very-light */
        }
        .button-container { text-align: center; margin: 25px 0; }
        .button {
            display: inline-block; padding: 12px 28px;
            background-color: #CF6DFC; /* --lavender-vibrant-purple */
            color: #ffffff !important; text-decoration: none; border-radius: 8px;
            font-weight: 600; font-size: 16px;
            box-shadow: 0 2px 5px rgba(0,0,0,0.1);
        }
        .button:hover { background-color: #a358d3; /* --lavender-darker-purple */ }
        .link-alt { color: #a358d3; text-decoration: none; }
        .link-alt:hover { text-decoration: underline; }
        .security-notice {
            margin: 25px 0; padding: 15px; background-color: #DBD4FF; /* --lavender-very-light */
            border-radius: 8px; border-left: 4px solid #BDB96A; /* --lavender-muted-green */
        }
        .security-notice p { margin: 0; font-size: 14px; }
        .footer {
            text-align: center; padding: 25px; font-size: 13px;
            color: #6c757d; background-color: #FDFBD4; /* --lavender-lightest-yellow */
            border-top: 1px solid #C1BFFF; /* --lavender-light-blue */
        }
        .footer p { margin: 5px 0; }
        .footer a { color: #a358d3; text-decoration: none; }
        /* Responsive styles */
        @media screen and (max-width: 600px) {
            .container {
                width: 100%;
                margin: 0;
                border-radius: 0;
            }
            .otp-code {
                font-size: 24px;
                padding: 10px;
                letter-spacing: 3px;
            }
        }
    </style>
</head>
<body style="margin: 0; padding: 0; background-color: #f8f9fa;">
    <!-- Email wrapper -->
    <table border="0" cellpadding="0" cellspacing="0" width="100%">
        <tr>
            <td align="center" valign="top">
                <!-- Main container -->
                <table class="container" border="0" cellpadding="0" cellspacing="0" width="600" style="border-collapse: collapse;">
                    <!-- Header -->
                    <tr>
                        <td class="header" style="padding: 30px 20px; text-align: center;">
                            <img src="https://i.postimg.cc/wvwbN8j2/logo-modified.png" alt="Twoem Online Productions Logo" class="logo" width="180" style="display: block; max-height: 70px; width: auto;" />
                            <h1 style="margin: 15px 0 0 0; font-size: 24px; font-weight: 700; color: #ffffff;">Password Reset Request</h1>
                        </td>
                    </tr>

                    <!-- Content -->
                    <tr>
                        <td class="content" style="padding: 25px;">
                            <div style="background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%); color: white; padding: 8px 16px; border-radius: 20px; font-size: 14px; font-weight: 600; display: inline-block; margin-bottom: 20px;">
                                🔐 Password Reset Request
                            </div>

                            <p style="margin: 0 0 20px 0; font-size: 18px;">Hello <strong><%= studentName %></strong>! 👋</p>

                            <div style="margin: 25px 0; padding: 20px; background: #fff8f0; border-radius: 12px; border-left: 4px solid #f093fb;">
                                <p style="margin: 0; color: #495057;">🔑 We received a request to reset the password for your account. If you made this request, please use the verification code below to proceed.</p>
                            </div>

                            <p style="margin: 20px 0 10px 0; text-align: center; font-weight: 600; font-size: 18px; color: #f093fb;">✨ Your Verification Code:</p>
                            <div class="otp-code" style="font-size: 36px; font-weight: 800; color: #f093fb; text-align: center; margin: 30px 0; padding: 25px; background: linear-gradient(135deg, rgba(240, 147, 251, 0.1) 0%, rgba(245, 87, 108, 0.1) 100%); border-radius: 16px; letter-spacing: 8px; border: 3px dashed #f093fb; font-family: 'Courier New', monospace; box-shadow: 0 8px 25px rgba(240, 147, 251, 0.2);">
                                <%= otp %>
                            </div>

                            <div style="text-align: center; margin: 25px 0;">
                                <p style="margin: 0 0 5px 0; font-size: 14px; color: #666;">⏰ This code expires in <strong style="color: #f093fb;">10 minutes</strong></p>
                                <p style="margin: 0; font-weight: 600; color: #dc3545;">🚨 Keep this code secure and don't share it with anyone!</p>
                            </div>

                            <% if (locals.resetLink) { %>
                                <p style="text-align: center; margin: 30px 0 20px 0;">
                                    <a href="<%= resetLink %>" class="button" style="display: inline-block; padding: 15px 30px; background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%); color: #ffffff !important; text-decoration: none; border-radius: 12px; font-weight: 700; box-shadow: 0 8px 25px rgba(240, 147, 251, 0.3);">
                                        🔐 Reset Password Now
                                    </a>
                                </p>
                            <% } %>

                            <div style="margin: 30px 0 20px 0; padding: 20px; background: linear-gradient(135deg, rgba(220, 53, 69, 0.05) 0%, rgba(245, 87, 108, 0.05) 100%); border-radius: 12px; border: 1px solid rgba(220, 53, 69, 0.1);">
                                <p style="margin: 0 0 10px 0; color: #dc3545; font-weight: 600;">🛡️ Security Notice</p>
                                <p style="margin: 0; font-size: 14px; color: #6c757d;">If you didn't request this password reset, please ignore this email or contact us if you have security concerns. Your account is safe! 🔒</p>
                            </div>

                            <p style="margin: 25px 0 0 0; font-size: 16px;">
                                Best regards,<br>
                                <strong style="color: #f093fb;">🎓 The Twoem Online Productions Team</strong><br>
                                <span style="font-size: 14px; color: #6c757d;">Your security is our priority 🛡️</span>
                            </p>
                        </td>
                    </tr>

                    <!-- Footer -->
                    <tr>
                        <td class="footer">
                            <p>&copy; <%= new Date().getFullYear() %> <%= process.env.EMAIL_FROM_NAME || 'Twoem Online Productions' %>. All rights reserved.</p>
                            <% if (locals.siteUrl) { %><p><a href="<%= siteUrl %>" class="link-alt">Visit our website</a></p><% } %>
                            <p>
                                Need help? Contact us at <a href="mailto:<%= process.env.CONTACT_RECEIVER_EMAIL %>" class="link-alt"><%= process.env.CONTACT_RECEIVER_EMAIL %></a>
                                <% if (process.env.COMPANY_PHONE) { %> | Phone: <%= process.env.COMPANY_PHONE %><% } %>
                            </p>
                        </td>
                    </tr>
                </table>
            </td>
        </tr>
    </table>
</body>
</html>
