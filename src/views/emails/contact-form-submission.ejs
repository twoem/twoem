<%# This content will be injected into main-email-layout.ejs %>
<% locals.preheaderText = `New message from ${senderName} via your website contact form.` %>

<h1 style="font-size: 22px; color: #0056b3; margin-bottom: 15px;">New Contact Form Submission</h1>
<p>You have received a new message through the contact form on the Twoem Online Productions website.</p>

<div class="email-content-card" style="background-color: #f0f8ff; border-left: 4px solid #007bff;">
    <h2 style="font-size: 18px; color: #0056b3; margin-top: 0;">Submission Details:</h2>
    <p><strong>From:</strong> <%= senderName %></p>
    <p><strong>Email:</strong> <a href="mailto:<%= senderEmail %>" style="color: #007bff;"><%= senderEmail %></a></p>
    <p><strong>Subject:</strong> <%= emailSubject %></p>
    <p><strong>Submitted On:</strong> <%= submissionDate %></p>
</div>

<div class="email-content-card" style="margin-top: 20px; background-color: #fdfdfe; border-left: 4px solid #28a745;">
    <h3 style="font-size: 18px; color: #19692c; margin-top: 0;">Message:</h3>
    <p style="white-space: pre-wrap; margin-bottom: 0;"><%- emailMessage.replace(/\n/g, '<br>') %></p>
</div>

<p style="text-align: center; margin-top: 25px; margin-bottom: 25px;">
    You can reply directly to this email to respond to <%= senderName %> (the "Reply-To" address has been set to their email).
</p>
<p style="text-align: center;">
    <a href="mailto:<%= senderEmail %>" class="button" style="background-color: #007bff; color: #ffffff !important;">Reply to <%= senderName %></a>
</p>

<p style="margin-top: 25px;">
    Please respond to this inquiry at your earliest convenience.
</p>
