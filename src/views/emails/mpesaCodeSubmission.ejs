<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= locals.subjectLine || 'Mpesa Payment Code Submission' %></title>
    <style>
        :root {
            --lavender-lightest-yellow: #FDFBD4;
            --lavender-muted-green: #BDB96A;
            --lavender-light-blue: #C1BFFF;
            --lavender-very-light: #DBD4FF;
            --lavender-vibrant-purple: #CF6DFC;
            --lavender-darker-purple: #a358d3;
        }
        body { font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; line-height: 1.6; color: #343a40; margin: 0; padding: 0; background-color: var(--lavender-very-light); }
        .email-wrapper { width: 100%; background-color: var(--lavender-very-light); padding: 20px 0; }
        .container { width: 100%; max-width: 600px; margin: 20px auto; background-color: #ffffff; border-radius: 12px; box-shadow: 0 4px 15px rgba(0,0,0,0.1); overflow: hidden; border: 1px solid var(--lavender-light-blue); }
        .header { background-color: var(--lavender-light-blue); padding: 30px 20px; text-align: center; }
        .logo { max-height: 60px; width: auto; display: block; margin: 0 auto 15px; }
        .header h1 { margin: 10px 0 0 0; font-size: 22px; font-weight: 600; color: #343a40; }
        .content { padding: 30px; font-size: 16px; line-height: 1.7; }
        .content p { margin-bottom: 18px; }
        .details-table { width: 100%; border-collapse: collapse; margin-bottom: 20px; font-size: 15px; }
        .details-table th, .details-table td { border: 1px solid var(--lavender-very-light); padding: 10px; text-align: left; }
        .details-table th { background-color: var(--lavender-very-light); color: var(--lavender-darker-purple); font-weight: 600; }
        .transaction-code-card { margin: 20px 0; padding: 20px; background-color: var(--lavender-lightest-yellow); border-radius: 8px; border: 1px dashed var(--lavender-muted-green); }
        .transaction-code-card h3 { margin-top:0; color: var(--lavender-darker-purple); font-size: 18px; }
        .transaction-code { font-family: monospace; white-space: pre-wrap; word-wrap: break-word; background-color: #fff; padding:10px; border-radius: 4px; border: 1px solid var(--lavender-very-light); }
        .footer { text-align: center; padding: 25px; font-size: 13px; color: #6c757d; background-color: var(--lavender-lightest-yellow); border-top: 1px solid var(--lavender-light-blue); }
        .footer p { margin: 5px 0; }
        .footer a { color: var(--lavender-darker-purple); text-decoration: none; }
    </style>
</head>
<body style="margin:0; padding:0; background-color: var(--lavender-very-light);">
    <table class="email-wrapper" border="0" cellpadding="0" cellspacing="0" width="100%">
        <tr><td align="center" valign="top">
        <table class="container" border="0" cellpadding="0" cellspacing="0" width="600" style="border-collapse: collapse;">
            <tr><td class="header">
                <% if (typeof logoUrl !== 'undefined' && logoUrl) { %>
                    <img src="<%= logoUrl %>" alt="<%= process.env.EMAIL_FROM_NAME || 'Site Logo' %>" class="logo">
                <% } %>
                <h1>Mpesa Payment Submission</h1>
            </td></tr>
            <tr><td class="content">
            <p>Dear Admin,</p>
            <p>A customer has submitted an Mpesa transaction code for payment verification. Please find the details below:</p>

            <table class="details-table">
                <tr>
                    <th>Customer Name:</th>
                    <td><%= customerName %></td>
                </tr>
                <tr>
                    <th>Account Number:</th>
                    <td><%= accountNumber %></td>
                </tr>
                <tr>
                    <th>Phone Number:</th>
                    <td><%= phoneNumber %></td>
                </tr>
                <tr>
                    <th>Current Due Amount:</th>
                    <td>KES <%= accountDueAmount ? accountDueAmount.toFixed(2) : 'N/A' %></td>
                </tr>
            </table>
            <div class="transaction-code-card">
                <h3>Submitted Mpesa Transaction Code/Message:</h3>
                <div class="transaction-code"><%= mpesaCode %></div>
            </div>

            <p>Please verify this payment and update the customer's account accordingly in the admin portal.</p>
            <p>Thank you.</p>
            </td></tr>
            <tr><td class="footer">
                <p>&copy; <%= new Date().getFullYear() %> <%= process.env.EMAIL_FROM_NAME || 'Twoem Online Productions' %>. All rights reserved.</p>
                <% if (locals.siteUrl) { %><p><a href="<%= siteUrl %>" class="link-alt">Visit our website</a></p><% } %>
                 <p>This is an automated notification from the Mynet Customer Portal.</p>
            </td></tr>
        </table>
        </td></tr>
    </table>
</body>
</html>
