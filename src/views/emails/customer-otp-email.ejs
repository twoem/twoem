<%# This content will be injected into main-email-layout.ejs %>
<% locals.preheaderText = 'Your One-Time Password (OTP) for Twoem Online Customer Portal.' %>

<h1 style="font-size: 22px; color: #0056b3; margin-bottom: 15px;">Customer Portal - Password Reset</h1>
<p>Hello <strong><%= customerName || 'Valued Customer' %></strong>,</p>
<p>We received a request to reset the password for your Twoem Online Internet Service Customer Portal account.</p>

<div class="email-content-card" style="background-color: #e6f7ff; border-left: 4px solid #17a2b8;">
    <p style="text-align: center; font-size: 16px; margin-bottom: 10px;">Your One-Time Password (OTP) is:</p>
    <p style="text-align: center; font-size: 32px; font-weight: bold; color: #17a2b8; letter-spacing: 3px; margin: 10px 0;">
        <%= otp %>
    </p>
    <p style="text-align: center; font-size: 14px; color: #555;">This OTP is valid for 10 minutes.</p>
</div>

<% if (locals.resetLink) { %>
    <p style="text-align: center; margin-top: 25px; margin-bottom: 25px;">
        Alternatively, you can click the button below to go directly to the reset page:
    </p>
    <p style="text-align: center;">
        <a href="<%= resetLink %>" class="button" style="background-color: #17a2b8; color: #ffffff !important;">Reset Your Password</a>
    </p>
     <p style="text-align: center; font-size: 0.9em; color: #666;">If the button doesn't work, copy and paste this link into your browser: <br><a href="<%= resetLink %>" style="color: #17a2b8; text-decoration: underline;"><%= resetLink %></a></p>
<% } %>

<p style="margin-top: 25px;">If you did not request this password reset, please ignore this email. Your account security is important to us.</p>
<p>Thank you,<br>The Twoem Online Productions Support Team</p>
