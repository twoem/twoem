<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= locals.subjectLine || 'Notification from Mynet' %></title>
    <style>
        :root {
            --lavender-lightest-yellow: #FDFBD4;
            --lavender-muted-green: #BDB96A;
            --lavender-light-blue: #C1BFFF;
            --lavender-very-light: #DBD4FF;
            --lavender-vibrant-purple: #CF6DFC;
            --lavender-darker-purple: #a358d3;
        }
        body { font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; line-height: 1.6; color: #343a40; margin: 0; padding: 0; background-color: var(--lavender-very-light); }
        .email-wrapper { width: 100%; background-color: var(--lavender-very-light); padding: 20px 0; }
        .container { width: 100%; max-width: 680px; margin: 0 auto; background-color: #ffffff; border-radius: 12px; box-shadow: 0 4px 15px rgba(0,0,0,0.1); overflow: hidden; border: 1px solid var(--lavender-light-blue); }
        .header { background-color: var(--lavender-light-blue); padding: 30px 20px; text-align: center; }
        .logo { max-height: 60px; width: auto; display: block; margin: 0 auto 15px; }
        .header h1 { margin: 10px 0 0 0; font-size: 22px; font-weight: 600; color: #343a40; } /* For site name if no logo */
        .content-body { padding: 30px; font-size: 16px; line-height: 1.7; }
        .content-body h1, .content-body h2, .content-body h3, .content-body h4, .content-body h5, .content-body h6 { color: var(--lavender-darker-purple); }
        .content-body p { margin-bottom: 1em; }
        .content-body a { color: var(--lavender-vibrant-purple); text-decoration: underline; }
        .content-body table { width: 100%; border-collapse: collapse; margin-bottom: 1em; }
        .content-body table th, .content-body table td { border: 1px solid var(--lavender-very-light); padding: 8px; }
        .content-body ul, .content-body ol { margin-bottom: 1em; padding-left: 20px; }
        .footer { text-align: center; padding: 25px; font-size: 13px; color: #6c757d; background-color: var(--lavender-lightest-yellow); border-top: 1px solid var(--lavender-light-blue); }
        .footer p { margin: 5px 0; }
        .footer a { color: var(--lavender-darker-purple); text-decoration: none; }
    </style>
</head>
<body style="margin:0; padding:0; background-color: var(--lavender-very-light);">
    <table class="email-wrapper" border="0" cellpadding="0" cellspacing="0" width="100%">
        <tr><td align="center" valign="top">
            <table class="container" border="0" cellpadding="0" cellspacing="0" width="100%">
                <tr><td class="header">
                    <% if (typeof logoUrl !== 'undefined' && logoUrl) { %>
                        <img src="<%= logoUrl %>" alt="<%= process.env.EMAIL_FROM_NAME || 'Site Logo' %>" class="logo">
                    <% } else if (process.env.EMAIL_FROM_NAME) { %>
                        <h1><%= process.env.EMAIL_FROM_NAME %></h1>
                    <% } %>
                </td></tr>
                <tr><td class="content-body">
                    <%- htmlBody %> <% /* Admin-composed HTML body is injected here */ %>
                </td></tr>
                <tr><td class="footer">
                    <p>&copy; <%= new Date().getFullYear() %> <%= process.env.EMAIL_FROM_NAME || 'Twoem Online Productions' %>. All rights reserved.</p>
                    <% if (locals.siteUrl) { %><p><a href="<%= siteUrl %>" class="link-alt">Visit our website</a></p><% } %>
                    <p>
                        Contact: <a href="mailto:<%= process.env.CONTACT_RECEIVER_EMAIL %>" class="link-alt"><%= process.env.CONTACT_RECEIVER_EMAIL %></a>
                        <% if (process.env.COMPANY_PHONE) { %> | Phone: <%= process.env.COMPANY_PHONE %><% } %>
                    </p>
                </td></tr>
            </table>
        </td></tr>
    </table>
</body>
</html>
