<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Twoem V2 | <%= title %></title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="icon" href="/favicon.ico" type="image/x-icon">
    <!-- Font Awesome for icons (optional, if you keep icons in the new design) -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
</head>
<body>
    <header>
        <div class="container">
            <div id="branding">
                <a href="/">
                    <img src="/logo.jpg" alt="Twoem V2 Logo">
                    <h1>Twoem V2</h1>
                </a>
            </div>
            <nav>
                <ul>
                    <li><a href="/" class="<%= title === 'Home' ? 'current' : '' %>">Home</a></li>
                    <li><a href="/services" class="<%= title === 'Our Services' ? 'current' : '' %>">Services</a></li>
                    <li><a href="/downloads" class="<%= title === 'Downloads' ? 'current' : '' %>">Downloads</a></li>
                    <li><a href="/gallery" class="<%= title === 'Gallery' ? 'current' : '' %>">Gallery</a></li>
                    <li><a href="/contact" class="<%= title === 'Contact Us' ? 'current' : '' %>">Contact</a></li>
                    <li class="dropdown">
                        <a href="#" class="<%= ['Customer Portal', 'Student Portal', 'Admin Portal'].includes(title) ? 'current' : '' %>">Portals <i class="fas fa-caret-down"></i></a>
                        <div class="dropdown-content">
                            <a href="/portals/customer" class="<%= title === 'Customer Portal' ? 'current' : '' %>">Customer Portal</a>
                            <a href="/portals/student" class="<%= title === 'Student Portal' ? 'current' : '' %>">Student Portal</a>
                            <a href="/portals/admin" class="<%= title === 'Admin Portal' ? 'current' : '' %>">Admin Portal</a>
                        </div>
                    </li>
                </ul>
            </nav>
        </div>
    </header>

    <div class="main-content">
        <div class="container">
            <%# Include flash messages partial %>
            <%- include('flash-messages') %>
            <!-- Page specific title, if needed, can be rendered by individual page templates -->
            <!-- e.g., <h1 class="page-title"><%= title %></h1> -->
        </div>
        <!-- The main container for page content will be closed in the footer -->
<!-- Actual page content will go here -->
