<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title ? title : 'Customer Portal' %> - Mynet</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <link rel="stylesheet" href="/css/style.css"> <!-- Main site style -->
    <!-- Add any customer portal specific styles here or in a separate CSS file -->
    <style>
        body { padding-top: 56px; /* Adjust if navbar height changes */ }
        .portal-navbar {
            background-color: #007bff; /* Placeholder color */
        }
        .portal-navbar .navbar-brand,
        .portal-navbar .nav-link {
            color: #fff;
        }
        .portal-navbar .nav-link:hover {
            color: #f0f0f0;
        }
        .navbar-brand img {
            max-height: 40px;
            margin-right: 10px;
        }
    </style>
</head>
<body>

<nav class="navbar navbar-expand-lg portal-navbar fixed-top">
    <div class="container">
        <a class="navbar-brand" href="/portal/customer/dashboard">
            <img src="/logo.png" alt="Mynet Logo"> Mynet Customer Portal
        </a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#customerNavbar" aria-controls="customerNavbar" aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="customerNavbar">
            <ul class="navbar-nav ms-auto mb-2 mb-lg-0">
                <li class="nav-item">
                    <a class="nav-link <%= title === 'Dashboard' ? 'active' : '' %>" href="/portal/customer/dashboard"><i class="fas fa-tachometer-alt"></i> Dashboard</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link <%= title === 'Subscription' ? 'active' : '' %>" href="/portal/customer/subscription"><i class="fas fa-file-invoice-dollar"></i> Subscription</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link <%= title === 'Make Payment' ? 'active' : '' %>" href="/portal/customer/pay"><i class="fas fa-credit-card"></i> Make Payment</a>
                </li>
                <li class="nav-item dropdown">
                    <a class="nav-link dropdown-toggle" href="#" id="navbarDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                        <i class="fas fa-user-circle"></i> <%= customer ? customer.firstName : 'Account' %>
                    </a>
                    <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="navbarDropdown">
                        <li><a class="dropdown-item" href="/portal/customer/profile/edit"><i class="fas fa-user-edit"></i> Edit Profile</a></li>
                        <li><a class="dropdown-item" href="/portal/customer/change-password"><i class="fas fa-key"></i> Change Password</a></li>
                        <li><hr class="dropdown-divider"></li>
                        <li><a class="dropdown-item" href="/portal/customer/logout"><i class="fas fa-sign-out-alt"></i> Logout</a></li>
                    </ul>
                </li>
                 <li class="nav-item">
                    <a class="nav-link" href="/" title="Back to Main Website"><i class="fas fa-home"></i> Main Site</a>
                </li>
            </ul>
        </div>
    </div>
</nav>
<div style="padding-top: 20px;"> <!-- Body padding placeholder -->
</div>
