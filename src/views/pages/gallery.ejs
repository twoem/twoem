<%- include('../partials/header', { title: 'Gallery' }) %>

<div class="container">
    <h1 class="page-title">Gallery</h1>

    <p class="text-center lead mb-4">A glimpse into our work, facilities, and the services we offer.</p>

    <%
    const galleryImages = [
        { src: "https://via.placeholder.com/400x300.png?text=Modern+Workspace", alt: "Modern Workspace", caption: "Our state-of-the-art workspace." },
        { src: "https://via.placeholder.com/400x300.png?text=Training+Session", alt: "Training Session", caption: "Students engaged in a training session." },
        { src: "https://via.placeholder.com/400x300.png?text=Printing+Services", alt: "Printing Services", caption: "High-quality printing equipment." },
        { src: "https://via.placeholder.com/400x300.png?text=Network+Setup", alt: "Network Setup", caption: "Professional network installation." },
        { src: "https://via.placeholder.com/400x300.png?text=Happy+Client", alt: "Happy Client", caption: "A satisfied client receiving support." },
        { src: "https://via.placeholder.com/400x300.png?text=Community+Event", alt: "Community Event", caption: "Twoem V2 participating in a community event." }
    ];
    %>

    <div class="gallery-grid">
        <% galleryImages.forEach(image => { %>
            <div class="gallery-item">
                <img src="<%= image.src %>" alt="<%= image.alt %>">
                <% if (image.caption) { %>
                    <p class="text-center mt-1"><%= image.caption %></p>
                <% } %>
            </div>
        <% }); %>
    </div>

    <section class="content-section text-center mt-4">
        <h2>Want to see more?</h2>
        <p>Visit our premises or contact us for more information about our services and projects.</p>
        <a href="/contact" class="btn">Contact Us</a>
    </section>
</div>

<%- include('../partials/footer') %>
