<%- include('../partials/adminHeader', { title: 'Admin Dashboard', admin: admin }) %>

<% /* The container-fluid is opened in adminHeader.ejs and its py-4 padding should be sufficient */ %>
    <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom" style="border-color: var(--lavender-light-blue) !important;">
        <h1 class="h2" style="color: var(--admin-nav-bg);">Admin Dashboard</h1>
        <% if (typeof admin !== 'undefined' && admin && admin.name) { %>
            <% /* Welcome message is now part of the adminHeader's user dropdown, but can add a sub-greeting here if desired */ %>
            <span class="fs-5" style="color: var(--lavender-muted-green);">Hello, <strong><%= admin.name %></strong>!</span>
        <% } %>
    </div>

    <p class="lead" style="color: var(--lavender-nav-text);">Welcome to the admin control panel. From here you can manage all aspects of the Twoem Online Productions website and student services.</p>

    <% if (typeof admin !== 'undefined' && admin && admin.email) { %>
        <p class="small" style="color: var(--lavender-muted-green);">Logged in as: <%= admin.email %></p>
    <% } %>

    <% if (typeof lastFeeUpdateDate !== 'undefined' && lastFeeUpdateDate) { %>
        <p class="small text-muted">
            Last fee entry:
            <% if (lastFeeUpdateAdminName && lastFeeUpdateAdminName !== 'Error') { %>
                by <strong><%= lastFeeUpdateAdminName %></strong>
            <% } else if (lastFeeUpdateAdminName === 'Error') { %>
                <em>Error loading admin name</em>
            <% } else { %>
                <em>N/A</em>
            <% } %>
            on <strong><%= new Date(lastFeeUpdateDate).toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric', hour: '2-digit', minute: '2-digit' }) %></strong>.
        </p>
    <% } else { %>
        <p class="small text-muted">No fee entries found yet.</p>
    <% } %>

    <%- include('../partials/flash-messages') %>


    <div class="row mt-4 g-4">
        <div class="col-md-6 col-lg-4 mb-4">
            <div class="card h-100 shadow-sm"> <% /* Card styling from adminHeader.ejs will apply */ %>
                <div class="card-body d-flex flex-column">
                    <h5 class="card-title"><i class="fas fa-users me-2"></i>Student Management</h5>
                    <p class="card-text small text-muted flex-grow-1">Register new students, view list, edit details, manage enrollments, marks, and fees.</p>
                    <a href="/admin/register-student" class="btn btn-sm btn-primary mt-auto mb-2 d-block">Register New Student</a>
                    <a href="/admin/students" class="btn btn-sm btn-info d-block" style="background-color: var(--lavender-light-blue); border-color: var(--lavender-light-blue); color: var(--admin-nav-bg);">View All Students</a>
                </div>
            </div>
        </div>
        <div class="col-md-6 col-lg-4 mb-4">
            <div class="card h-100 shadow-sm">
                <div class="card-body d-flex flex-column">
                    <h5 class="card-title"><i class="fas fa-wifi me-2"></i>Customer Management</h5>
                    <p class="card-text small text-muted flex-grow-1">Register new internet customers, view list, edit details, and manage payments.</p>
                    <a href="/admin/customers/add" class="btn btn-sm btn-primary mt-auto mb-2 d-block">Add New Customer</a>
                    <a href="/admin/customers" class="btn btn-sm btn-info d-block" style="background-color: var(--lavender-light-blue); border-color: var(--lavender-light-blue); color: var(--admin-nav-bg);">View All Customers</a>
                </div>
            </div>
        </div>
        <div class="col-md-6 col-lg-4 mb-4">
            <div class="card h-100 shadow-sm">
                <div class="card-body d-flex flex-column">
                    <h5 class="card-title"><i class="fas fa-book me-2"></i>Course Management</h5>
                    <p class="card-text small text-muted flex-grow-1">Define and manage all courses offered.</p>
                    <a href="/admin/courses" class="btn btn-sm btn-primary mt-auto d-block">Manage Courses</a>
                </div>
            </div>
        </div>
        <div class="col-md-6 col-lg-4 mb-4">
            <div class="card h-100 shadow-sm">
                <div class="card-body d-flex flex-column">
                    <h5 class="card-title"><i class="fas fa-bullhorn me-2"></i>Notifications</h5>
                    <p class="card-text small text-muted flex-grow-1">Create and manage notifications for students.</p>
                    <a href="/admin/notifications" class="btn btn-sm btn-primary mt-auto d-block">Manage Notifications</a>
                </div>
            </div>
        </div>
        <div class="col-md-6 col-lg-4 mb-4">
            <div class="card h-100 shadow-sm">
                <div class="card-body d-flex flex-column">
                    <h5 class="card-title"><i class="fas fa-envelope me-2"></i>Email Tools</h5>
                    <p class="card-text small text-muted flex-grow-1">Send emails, test templates, and view logs.</p>
                    <a href="/admin/compose-email" class="btn btn-sm btn-primary mt-auto d-block mb-2">Compose Email</a>
                    <a href="/admin/emails/send" class="btn btn-sm btn-outline-primary d-block mb-2">Bulk Email (Students)</a>
                    <a href="/admin/emails/test" class="btn btn-sm btn-outline-primary d-block mb-2">Test Email Templates</a>
                    <a href="/admin/emails/logs" class="btn btn-sm btn-info d-block" style="background-color: var(--lavender-light-blue); border-color: var(--lavender-light-blue); color: var(--admin-nav-bg);">Email Logs</a>
                </div>
            </div>
        </div>
        <div class="col-md-6 col-lg-4 mb-4">
            <div class="card h-100 shadow-sm">
                <div class="card-body d-flex flex-column">
                    <h5 class="card-title"><i class="fas fa-book-reader me-2"></i>Study Resources</h5>
                    <p class="card-text small text-muted flex-grow-1">Upload and manage study materials for students.</p>
                    <a href="/admin/study-resources" class="btn btn-sm btn-primary mt-auto d-block">Manage Resources</a>
                </div>
            </div>
        </div>
        <div class="col-md-6 col-lg-4 mb-4">
            <div class="card h-100 shadow-sm">
                <div class="card-body d-flex flex-column">
                    <h5 class="card-title"><i class="fas fa-file-alt me-2"></i>Content Management</h5>
                    <p class="card-text small text-muted flex-grow-1">Manage public downloads and other site content.</p>
                    <a href="/admin/documents" class="btn btn-sm btn-primary d-block mb-2">Manage Downloads</a>
                    <% /* <a href="#" class="btn btn-sm btn-secondary disabled d-block mt-auto">Manage Gallery (Soon)</a> */ %>
                </div>
            </div>
        </div>
        <div class="col-md-6 col-lg-4 mb-4">
            <div class="card h-100 shadow-sm">
                <div class="card-body d-flex flex-column">
                    <h5 class="card-title"><i class="fas fa-cogs me-2"></i>System & Site Settings</h5>
                    <p class="card-text small text-muted flex-grow-1">Manage WiFi, view admin action logs.</p>
                    <a href="/admin/settings/wifi" class="btn btn-sm btn-primary mb-2 d-block">Manage WiFi Settings</a>
                    <a href="/admin/action-logs" class="btn btn-sm btn-info d-block mb-2" style="background-color: var(--lavender-light-blue); border-color: var(--lavender-light-blue); color: var(--admin-nav-bg);">View Action Logs</a>
                    <% /* <a href="#" class="btn btn-sm btn-secondary disabled d-block mt-auto">Upload Backup (Soon)</a> */ %>
                </div>
            </div>
        </div>
    </div>

<% /* adminFooter will close the container-fluid from adminHeader */ %>
<%- include('../partials/adminFooter') %>
