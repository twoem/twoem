<%# This page will now be rendered within admin_layout.ejs %>
<%# The <%- body %> in admin_layout.ejs will inject the content below. %>
<%# The title for the layout will be passed from the route handler. %>

<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
    <h1 class="h2">Admin Dashboard</h1>
    <div class="btn-toolbar mb-2 mb-md-0">
        <% if (typeof admin !== 'undefined' && admin && admin.name) { %>
            <span class="me-3">Hello, <strong><%- admin.name %></strong>!</span>
        <% } else { %>
            <span class="me-3">Hello, Admin!</span>
        <% } %>
        <form action="/admin/logout" method="POST" class="d-inline">
            <button type="submit" class="btn btn-sm btn-outline-secondary">Logout</button>
        </form>
    </div>
</div>

<p>Welcome to the admin control panel. From here you can manage all aspects of the Twoem Online Productions website and student services.</p>

<% if (typeof admin !== 'undefined' && admin && admin.email) { %>
    <p class="small text-muted">Logged in as: <%- admin.email %></p>
<% } %>
<p class="small text-muted">Last student/fees update by: [Admin Name] on [Date] (Placeholder - to be implemented)</p>

<div class="row mt-4 g-4">
    <div class="col-12">
        <div class="alert alert-info" role="alert">
            <h4 class="alert-heading"><i class="fas fa-info-circle me-2"></i>Quick Access Removed</h4>
            <p>The quick access cards have been removed from the dashboard. Please use the sidebar navigation on the left to access different management sections.</p>
            <hr>
            <p class="mb-0">This area can be used in the future to display important statistics, recent activities, or alerts.</p>
        </div>
    </div>

    <!-- Example of how you might add summary cards back in, if desired, but not for navigation -->
    <div class="col-md-6 col-lg-4">
        <div class="card text-white bg-primary mb-3 shadow">
            <div class="card-header">Registered Students</div>
            <div class="card-body">
                <h5 class="card-title"><i class="fas fa-users me-2"></i> <%= typeof studentStats !== 'undefined' && studentStats && studentStats.totalStudents ? studentStats.totalStudents : 'N/A' %> Students</h5>
                <p class="card-text">Total number of students in the system.</p>
                <a href="/admin/students" class="btn btn-sm btn-light">View Students</a>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-lg-4">
        <div class="card text-white bg-success mb-3 shadow">
            <div class="card-header">Active Courses</div>
            <div class="card-body">
                <h5 class="card-title"><i class="fas fa-book me-2"></i> <%= typeof courseStats !== 'undefined' && courseStats && courseStats.totalCourses ? courseStats.totalCourses : 'N/A' %> Courses</h5>
                <p class="card-text">Total number of active courses offered.</p>
                <a href="/admin/courses" class="btn btn-sm btn-light">Manage Courses</a>
            </div>
        </div>
    </div>
     <div class="col-md-6 col-lg-4">
        <div class="card text-white bg-info mb-3 shadow">
            <div class="card-header">Internet Customers</div>
            <div class="card-body">
                <h5 class="card-title"><i class="fas fa-network-wired me-2"></i> <%= typeof customerStats !== 'undefined' && customerStats && customerStats.totalCustomers ? customerStats.totalCustomers : 'N/A' %> Customers</h5>
                <p class="card-text">Total number of internet subscribers.</p>
                <a href="/admin/customers" class="btn btn-sm btn-light">Manage Customers</a>
            </div>
        </div>
    </div>

    <!-- Placeholder for future content like charts or recent activity logs -->
    <div class="col-12 mt-4">
        <h4>Recent Activity (Placeholder)</h4>
        <ul class="list-group shadow-sm">
            <li class="list-group-item">Admin John Doe registered a new student.</li>
            <li class="list-group-item">Customer Jane Smith's payment was verified.</li>
            <li class="list-group-item">New course "Advanced Web Development" added.</li>
        </ul>
    </div>
</div>
