<%- include('../partials/header', { title: 'Our Services' }) %>

<div class="container">
    <h1 class="page-title">Our Services</h1>

    <p class="text-center lead mb-4">We offer a variety of services to meet your digital and professional needs. Explore our offerings below.</p>

    <% if (typeof error_msg_direct !== 'undefined' && error_msg_direct) { %>
        <div class="flash-message flash-error"><%= error_msg_direct %></div>
    <% } %>

    <% if (typeof courses !== 'undefined' && courses.length > 0) { %>
        <section class="content-section">
            <h2>Available Courses & Training</h2>
            <div class="course-list">
                <% courses.forEach(course => { %>
                    <div class="course-item">
                        <h3><%= course.name %></h3>
                        <% if (course.description) { %>
                            <p><%= course.description %></p>
                        <% } %>
                        <!-- Add more details or a link if needed -->
                    </div>
                <% }); %>
            </div>
        </section>
    <% } else if (typeof courses !== 'undefined') { %>
        <section class="content-section">
            <h2>Available Courses & Training</h2>
            <p>No courses are currently listed. Please check back later or contact us for more information.</p>
        </section>
    <% } %>

    <section class="content-section">
        <h2>Digital & Office Services</h2>
        <div class="card-container">
            <div class="card">
                <h3>Printing & Documentation</h3>
                <p>High-quality printing, copying, scanning, and document binding services.</p>
                <a href="/contact?subject=Printing Inquiry" class="btn">Inquire</a>
            </div>
            <div class="card">
                <h3>Graphic Design</h3>
                <p>Creative design services for logos, brochures, business cards, and more.</p>
                <a href="/contact?subject=Graphic Design Inquiry" class="btn">Inquire</a>
            </div>
            <div class="card">
                <h3>IT Support & Consultation</h3>
                <p>Expert IT support, troubleshooting, and consultation for businesses and individuals.</p>
                <a href="/contact?subject=IT Support Inquiry" class="btn">Inquire</a>
            </div>
            <div class="card">
                <h3>Web Development</h3>
                <p>Custom website design and development services to establish your online presence.</p>
                <a href="/contact?subject=Web Development Inquiry" class="btn">Inquire</a>
            </div>
        </div>
    </section>

    <section class="content-section text-center">
        <h2>Looking for something specific?</h2>
        <p>If you don't see a service listed, please contact us. We may be able to assist you or provide a custom solution.</p>
        <a href="/contact" class="btn">Contact Us</a>
    </section>
</div>

<%- include('../partials/footer') %>
