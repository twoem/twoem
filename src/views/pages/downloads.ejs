<%- include('../partials/header', { title: 'Downloads' }) %>
<%- include('../partials/navbar') %>

<main class="pt-0"> <!-- Remove mt-5 if using full-width header image -->
    <!-- Optional Header Image for Downloads Page -->
    <div class="container-fluid px-0 mb-5">
        <div style="background: url('/images/downloads/downloads-header.jpg') no-repeat center center; background-size: cover; height: 30vh; display: flex; align-items: center; justify-content: center; text-align: center;">
            <h1 class="display-4 fw-bold text-white page-title-hero" style="text-shadow: 1px 1px 3px rgba(0,0,0,0.7);">Downloads</h1>
        </div>
    </div>

    <div class="container">
        <div class="row">
            <div class="col-12 text-center">
                <p class="lead mb-5">Find public documents, eulogies, and other resources available for download from Twoem Online Productions.</p>
                <%- include('../partials/flash-messages') %>
            </div>
        </div>

        <% if ( (publicDocs && publicDocs.length > 0) || (eulogyDocs && eulogyDocs.length > 0) ) { %>
            <% if (publicDocs && publicDocs.length > 0) { %>
                <h3 class="mt-0 mb-4 text-center section-title gradient-text">
                    <i class="fas fa-file-alt me-2"></i>Public Documents
                </h3>
                <div class="row g-4 mb-5">
                    <% publicDocs.forEach(function(doc) { %>
                        <div class="col-md-6 col-lg-4">
                            <div class="card h-100 shadow-lg download-card">
                                <div class="card-body d-flex flex-column">
                                    <h5 class="card-title gradient-text"><%= doc.title %></h5>
                                    <p class="card-text small text-muted flex-grow-1"><%= doc.description || 'No description available.' %></p>
                                    <p class="card-text"><small class="text-muted">Uploaded: <%= new Date(doc.created_at).toLocaleDateString() %></small></p>
                                    <a href="/download-redirect/<%= doc.id %>" class="btn btn-primary mt-auto stretched-link">
                                        <i class="fas fa-download me-2"></i>Download
                                    </a>
                                </div>
                            </div>
                        </div>
                    <% }); %>
                </div>
            <% } %>

            <% if (eulogyDocs && eulogyDocs.length > 0) { %>
                <h3 class="mt-5 mb-4 text-center section-title gradient-text">
                    <i class="fas fa-book-dead me-2"></i>Eulogy Documents
                </h3>
                <p class="text-center text-muted mb-4">These documents are available for a limited time.</p>
                <div class="row g-4">
                    <% eulogyDocs.forEach(function(doc) {
                        let expiryText = '';
                        let effectiveExpiry;
                        if (doc.expiry_date) {
                            effectiveExpiry = new Date(doc.expiry_date);
                        } else {
                            effectiveExpiry = new Date(doc.created_at);
                            effectiveExpiry.setDate(effectiveExpiry.getDate() + 7); // Default 7 days
                        }
                        const daysRemaining = Math.ceil((effectiveExpiry.setHours(23,59,59,999) - new Date()) / (1000 * 60 * 60 * 24));
                        if (daysRemaining <= 0) expiryText = 'Expired';
                        else if (daysRemaining === 1) expiryText = 'Expires today';
                        else expiryText = `Expires in ${daysRemaining} days (${effectiveExpiry.toLocaleDateString()})`;
                    %>
                        <div class="col-md-6 col-lg-4">
                            <div class="card h-100 shadow-lg download-card eulogy">
                                 <div class="card-header bg-secondary text-white small text-center py-1">Eulogy - <%= expiryText %></div>
                                <div class="card-body d-flex flex-column">
                                    <h5 class="card-title gradient-text"><%= doc.title %></h5>
                                    <p class="card-text small text-muted flex-grow-1"><%= doc.description || 'No description available.' %></p>
                                     <p class="card-text"><small class="text-muted">Posted: <%= new Date(doc.created_at).toLocaleDateString() %></small></p>
                                    <a href="/download-redirect/<%= doc.id %>" class="btn btn-primary mt-auto stretched-link">
                                        <i class="fas fa-download me-2"></i>Download
                                    </a>
                                </div>
                            </div>
                        </div>
                    <% }); %>
                </div>
            <% } %>
        <% } else { %>
            <div class="alert alert-info text-center col-md-8 mx-auto">
                <i class="fas fa-info-circle fa-2x me-2 align-middle"></i>
                <span class="align-middle">No documents are currently available for download. Please check back later.</span>
            </div>
        <% } %>
    </div>
</main>

<style>
    .download-card {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        border: none;
        border-radius: var(--border-radius-lg);
    }
    .download-card:hover {
        transform: translateY(-5px);
        box-shadow: var(--shadow-xl) !important;
    }
    .download-card .card-title {
        font-size: 1.25rem;
        font-weight: 600;
    }
    .download-card.eulogy {
        border-top: 4px solid var(--secondary-color);
    }
    .section-title {
        font-weight: 700;
    }
</style>

<%- include('../partials/footer') %>
