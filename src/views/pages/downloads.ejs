<%- include('../partials/header', { title: 'Downloads' }) %>

<div class="container">
    <h1 class="page-title">Downloads</h1>

    <p class="text-center lead mb-4">Find public documents, resources, and other files available for download.</p>

    <% if (typeof error_msg_direct !== 'undefined' && error_msg_direct) { %>
        <div class="flash-message flash-error"><%= error_msg_direct %></div>
    <% } %>

    <section class="download-section">
        <h2>Public Documents</h2>
        <% if (publicDocs && publicDocs.length > 0) { %>
            <div class="download-list">
                <% publicDocs.forEach(function(doc) { %>
                    <div class="download-item">
                        <div class="download-item-info">
                            <h3><%= doc.title %></h3>
                            <% if (doc.description) { %><p><%= doc.description %></p><% } %>
                            <p class="file-type">Type: <%= doc.type || 'General' %></p>
                        </div>
                        <a href="/redirect?url=<%= encodeURIComponent(doc.file_url) %>&title=<%= encodeURIComponent(doc.title) %>" class="btn">
                            <i class="fas fa-download"></i> Download
                        </a>
                    </div>
                <% }); %>
            </div>
        <% } else { %>
            <p>No public documents currently available.</p>
        <% } %>
    </section>

    <section class="download-section">
        <h2>Eulogy Documents</h2>
        <p class="text-muted">These documents are typically available for a limited time.</p>
        <% if (eulogyDocs && eulogyDocs.length > 0) { %>
            <div class="download-list">
                <% eulogyDocs.forEach(function(doc) { %>
                    <%
                        let expiryText = '';
                        let effectiveExpiry;
                        if (doc.expiry_date) {
                            effectiveExpiry = new Date(doc.expiry_date);
                        } else {
                            effectiveExpiry = new Date(doc.created_at);
                            effectiveExpiry.setDate(effectiveExpiry.getDate() + 7); // Default 7 days
                        }
                        const daysRemaining = Math.ceil((effectiveExpiry - new Date()) / (1000 * 60 * 60 * 24));

                        if (daysRemaining <= 0) expiryText = 'Expired';
                        else if (daysRemaining === 1) expiryText = 'Expires today';
                        else if (daysRemaining <= 7) expiryText = `Expires in ${daysRemaining} days`;
                        else expiryText = `Expires on ${effectiveExpiry.toLocaleDateString()}`;
                    %>
                    <div class="download-item">
                        <div class="download-item-info">
                            <h3><%= doc.title %></h3>
                            <% if (doc.description) { %><p><%= doc.description %></p><% } %>
                            <p class="file-type">Availability: <span style="color: #d9534f;"><%= expiryText %></span></p>
                        </div>
                        <a href="/redirect?url=<%= encodeURIComponent(doc.file_url) %>&title=<%= encodeURIComponent(doc.title) %>" class="btn">
                            <i class="fas fa-download"></i> Download
                        </a>
                    </div>
                <% }); %>
            </div>
        <% } else { %>
            <p>No eulogy documents currently available.</p>
        <% } %>
    </section>

</div>

<%- include('../partials/footer') %>
