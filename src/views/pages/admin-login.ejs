<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <link rel="stylesheet" href="/css/style.css">
    <style>
        :root {
            --lavender-lightest-yellow: #FDFBD4;
            --lavender-muted-green: #BDB96A;
            --lavender-light-blue: #C1BFFF;
            --lavender-very-light: #DBD4FF;
            --lavender-vibrant-purple: #CF6DFC;
            --lavender-darker-purple: #a358d3;
            --admin-nav-bg: #583759; /* Using a distinct admin color from header for consistency */
        }
        body.admin-login-page {
            background: linear-gradient(135deg, var(--lavender-light-blue) 0%, var(--lavender-very-light) 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 1rem;
        }
        .admin-login-card {
            background: rgba(255, 255, 255, 0.98);
            border: none;
            border-radius: 1rem; /* Softer radius */
            box-shadow: 0 15px 35px rgba(50, 50, 93, 0.1), 0 5px 15px rgba(0, 0, 0, 0.07);
            overflow: hidden;
            position: relative;
            width: 100%;
            max-width: 450px;
        }
        .admin-login-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 6px; /* Thicker accent line */
            background: var(--admin-nav-bg); /* Admin accent color */
        }
        .login-header {
            text-align: center;
            margin-bottom: 2rem;
        }
        .login-icon {
            width: 70px; /* Slightly smaller */
            height: 70px;
            margin: 0 auto 1rem;
            background: var(--admin-nav-bg);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 1.8rem; /* Adjusted icon size */
        }
        .login-title {
            color: var(--admin-nav-bg);
            font-weight: 700;
            margin-bottom: 0.25rem;
        }
        .login-subtitle {
            color: #6c757d; /* Bootstrap's muted color */
            font-size: 0.95rem;
        }
        .form-floating {
            margin-bottom: 1.25rem;
        }
        .form-floating > .form-control {
            border: 1px solid var(--lavender-very-light);
            border-radius: 0.5rem;
            padding: 1rem 0.75rem;
            background: #fff;
            transition: all 0.2s ease-in-out;
        }
        .form-floating > .form-control:focus {
            border-color: var(--lavender-vibrant-purple);
            box-shadow: 0 0 0 0.25rem rgba(207, 109, 252, 0.25);
            background: white;
        }
        .form-floating > label {
            color: #6c757d;
        }
        .login-btn {
            background: var(--lavender-vibrant-purple);
            border: none;
            border-radius: 0.5rem;
            padding: 0.85rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            transition: background-color 0.2s ease-in-out, transform 0.1s ease;
        }
        .login-btn:hover {
            background: var(--lavender-darker-purple);
            transform: translateY(-1px);
        }
        .back-link a {
            color: var(--admin-nav-bg);
            font-weight: 500;
        }
        .back-link a:hover {
            color: var(--lavender-vibrant-purple);
        }
    </style>
</head>
<body class="admin-login-page">

    <div class="admin-login-card">
        <div class="card-body p-4 p-md-5"> <% /* More padding on larger screens */ %>
            <div class="login-header">
                <div class="login-icon">
                    <i class="fas fa-user-shield"></i>
                </div>
                <h2 class="login-title h3">Admin Portal</h2>
                <p class="login-subtitle">Secure Sign In</p>
            </div>

            <%- include('../partials/flash-messages') %>

            <form action="/portals/admin/login" method="POST" id="adminLoginForm">
                <div class="form-floating">
                    <input type="email" class="form-control" id="email" name="email" placeholder="name@example.com" required value="<%= locals.email || '' %>">
                    <label for="email"><i class="fas fa-envelope me-2 opacity-75"></i>Email Address</label>
                </div>

                <div class="form-floating">
                    <input type="password" class="form-control" id="password" name="password" placeholder="Password" required>
                    <label for="password"><i class="fas fa-lock me-2 opacity-75"></i>Password</label>
                </div>

                <div class="d-grid mt-4">
                    <button type="submit" class="btn btn-primary login-btn">
                        <i class="fas fa-sign-in-alt me-2"></i>Sign In
                    </button>
                </div>
            </form>
            <div class="text-center mt-4 back-link">
                 <small><a href="/"><i class="fas fa-arrow-left me-1"></i>Back to Main Website</a></small>
            </div>
        </div>
    </div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const loginForm = document.getElementById('adminLoginForm');
    if (loginForm) {
        loginForm.addEventListener('submit', function(e) {
            const button = this.querySelector('button[type="submit"]');
            button.innerHTML = '<span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>Signing In...';
            button.disabled = true;
        });
    }
});
</script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
