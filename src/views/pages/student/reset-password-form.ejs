<%- include('../../partials/header', { title: title }) %>
<%- include('../../partials/navbar') %>

<main class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-7 col-lg-6">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h3 class="mb-0"><i class="fas fa-unlock-alt me-2"></i><%= title %></h3>
                </div>
                <div class="card-body p-4">
                    <%- include('../../partials/flash-messages') %>

                    <% if (locals.token && locals.token.length > 0) { %>
                        <div class="alert alert-info small">
                            <i class="fas fa-info-circle me-1"></i> You are resetting your password using a secure link. You may not need to enter an OTP if this link is valid.
                        </div>
                    <% } else { %>
                        <p class="text-muted">An OTP has been sent to your registered email address. Please enter it below along with your new password.</p>
                    <% } %>

                    <form action="/student/reset-password" method="POST">
                        <%# This hidden field will carry the token if present in the URL %>
                        <input type="hidden" name="urlToken" value="<%= locals.token || '' %>">

                        <%# Registration number is primarily for OTP flow, but good to have if user got here via OTP path %>
                        <input type="hidden" name="registrationNumber" value="<%= locals.registrationNumber || '' %>">

                        <%# OTP field is always present, but its necessity depends on whether a valid urlToken is also submitted %>
                        <div class="mb-3">
                            <label for="otp" class="form-label">One-Time Password (OTP)</label>
                            <input type="text" class="form-control" id="otp" name="otp"
                                   inputmode="numeric" pattern="\\d{6}" title="Enter 6-digit OTP"
                                   placeholder="Enter 6-digit OTP from email"
                                   <%= (locals.token && locals.token.length > 0) ? '' : 'required' %>>
                            <small class="form-text text-muted">
                                <%= (locals.token && locals.token.length > 0) ? "If you received an OTP, enter it here. Otherwise, the link you followed will be used." : "Check your email for the 6-digit OTP." %>
                            </small>
                        </div>

                        <div class="mb-3">
                            <label for="newPassword" class="form-label">New Password</label>
                            <input type="password" class="form-control" id="newPassword" name="newPassword" required minlength="<%= locals.passwordMinLength || 8 %>">
                            <div class="form-text text-muted">Minimum <%= locals.passwordMinLength || 8 %> characters.</div>
                        </div>
                        <div class="mb-3">
                            <label for="confirmNewPassword" class="form-label">Confirm New Password</label>
                            <input type="password" class="form-control" id="confirmNewPassword" name="confirmNewPassword" required>
                        </div>
                        <div class="d-grid gap-2 mt-4">
                            <button type="submit" class="btn btn-primary btn-lg">
                                <i class="fas fa-check-circle me-2"></i>Reset Password
                            </button>
                            <a href="/student/login" class="btn btn-outline-secondary">
                                <i class="fas fa-arrow-left me-2"></i>Back to Login
                            </a>
                        </div>
                    </form>
                    <hr class="my-4">
                    <p class="text-center small">
                        <a href="/student/login#forgot-password-panel" class="text-decoration-none">Didn't receive an OTP/link or it expired? Request again.</a>
                    </p>
                </div>
            </div>
        </div>
    </div>
</main>

<%- include('../../partials/footer') %>
