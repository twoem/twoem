<% /* This page is rendered within layouts/portal-student.ejs */ %>
<% /* Flash messages are handled by the layout */ %>

<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
    <h1 class="h2">My Financials</h1>
</div>

<div class="card shadow-sm mb-4">
    <div class="card-header bg-light">
        <h5 class="mb-0"><i class="fas fa-file-invoice-dollar me-2"></i>Fee Summary</h5>
    </div>
    <div class="card-body">
        <div class="row">
            <div class="col-md-4 mb-3 mb-md-0">
                <p class="mb-1 text-muted">Total Fees Due:</p>
                <h4 class="fw-bold">KES <%= totalFeesDue %></h4>
            </div>
            <div class="col-md-4 mb-3 mb-md-0">
                <p class="mb-1 text-muted">Total Amount Paid:</p>
                <h4 class="fw-bold text-success">KES <%= totalAmountPaid %></h4>
            </div>
            <div class="col-md-4">
                <p class="mb-1 text-muted">Remaining Balance:</p>
                <h4 class="fw-bold <%= parseFloat(feesBalance) <= 0 ? 'text-success' : 'text-danger' %>">
                    KES <%= feesBalance %>
                    (<%= parseFloat(feesBalance) <= 0 ? (parseFloat(feesBalance) < 0 ? 'Overpaid' : 'Cleared') : 'Owing' %>)
                </h4>
            </div>
        </div>
        <p class="text-muted small mt-2">This summary reflects all charges and payments logged on your account.</p>
    </div>
</div>

<% if (feeLogs && feeLogs.length > 0) { %>
    <h4 class="mt-4">Detailed Transaction Log</h4>
    <div class="table-responsive card shadow-sm">
        <table class="table table-striped table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th scope="col">Date</th>
                    <th scope="col">Description</th>
                    <th scope="col" class="text-end">Charge (KES)</th>
                    <th scope="col" class="text-end">Payment (KES)</th>
                    <th scope="col">Payment Method</th>
                    <th scope="col">Notes</th>
                </tr>
            </thead>
            <tbody>
                <% feeLogs.forEach(function(log) { %>
                    <tr>
                        <td><%= new Date(log.payment_date || log.created_at).toLocaleDateString() %></td>
                        <td><%= log.description %></td>
                        <td class="text-end"><%= log.total_amount_val > 0 ? log.total_amount_val.toFixed(2) : '-' %></td>
                        <td class="text-end"><%= log.amount_paid_val > 0 ? log.amount_paid_val.toFixed(2) : '-' %></td>
                        <td><%= log.payment_method || '-' %></td>
                        <td><%= log.notes || '-' %></td>
                    </tr>
                <% }); %>
            </tbody>
        </table>
    </div>
<% } else { %>
    <div class="alert alert-info mt-4">
        <i class="fas fa-info-circle me-2"></i>No fee transactions found for your account.
    </div>
<% } %>

<div class="mt-4">
    <a href="/portals/student/dashboard" class="btn btn-outline-secondary"><i class="fas fa-arrow-left me-1"></i> Back to Dashboard</a>
</div>
