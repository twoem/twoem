<%# This page is rendered within layouts/student_layout.ejs %>
<%# viewData from the controller is available here %>
<% const fees = viewData.fees; %>
<% const overallBalance = viewData.overallBalance; %>
<% const student = viewData.student; %>


<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="/student/dashboard">Dashboard</a></li>
        <li class="breadcrumb-item active" aria-current="page"><%= viewData.title || 'My Fee Statement' %></li>
    </ol>
</nav>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h2"><i class="fas fa-file-invoice-dollar me-2"></i><%= viewData.title || 'My Fee Statement' %></h1>
</div>
<hr class="my-4">

<% if (viewData.errorLoading) { %>
    <div class="alert alert-danger" role="alert">
        <h4 class="alert-heading">Error Loading Fee Statement!</h4>
        <p>We encountered an issue trying to load your fee data. Please try again later.</p>
        <% if (viewData.errorMessage) { %>
            <p class="mb-0"><small>Details: <%= viewData.errorMessage %></small></p>
        <% } %>
    </div>
<% else { %>
    <div class="card shadow-sm mb-4">
        <div class="card-header bg-light">
            <h4 class="h5 mb-0">Fee Summary</h4>
        </div>
        <div class="card-body">
            <h3 class="display-6">Overall Balance: KES <%= overallBalance.toFixed(2) %>
                (<span class="fw-bold <%= overallBalance <= 0 ? 'text-success' : 'text-danger' %>">
                    <%= overallBalance <= 0 ? (overallBalance < 0 ? 'Overpaid' : 'Cleared') : 'Owing' %>
                </span>)
            </h3>
            <p class="text-muted">This summary reflects all charges and payments logged on your account by the administration.</p>
        </div>
    </div>

    <% if (fees && fees.length > 0) { %>
        <div class="card shadow-sm">
            <div class="card-header">
                <h4 class="h5 mb-0">Detailed Transactions</h4>
            </div>
            <div class="card-body p-0"> <%# Remove padding for full-width table in card %>
                <div class="table-responsive">
                    <table class="table table-striped table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th scope="col">Date</th>
                                <th scope="col">Description</th>
                                <th scope="col" class="text-end">Charge (KES)</th>
                                <th scope="col" class="text-end">Payment (KES)</th>
                                <th scope="col" class="text-end">Entry Balance (KES)</th>
                                <th scope="col">Notes</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% fees.forEach(function(fee) { %>
                                <tr>
                                    <td><%= new Date(fee.payment_date || fee.created_at).toLocaleDateString() %></td>
                                    <td><%= fee.description %></td>
                                    <td class="text-end"><%= fee.total_amount > 0 ? fee.total_amount.toFixed(2) : '-' %></td>
                                    <td class="text-end"><%= fee.amount_paid > 0 ? fee.amount_paid.toFixed(2) : '-' %></td>
                                    <td class="text-end"><%= fee.balance.toFixed(2) %></td>
                                    <td><%= fee.notes || '-' %></td>
                                </tr>
                            <% }); %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    <% } else { %>
        <div class="alert alert-info">
            <i class="fas fa-info-circle me-2"></i>No fee transactions found for your account.
        </div>
    <% } %>
<% } %>

<div class="mt-4">
    <a href="/student/dashboard" class="btn btn-secondary"><i class="fas fa-arrow-left me-2"></i>Back to Dashboard</a>
</div>
