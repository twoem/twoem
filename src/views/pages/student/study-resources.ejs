<% /* This page is rendered within layouts/portal-student.ejs */ %>
<% /* Flash messages are handled by the layout */ %>

<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
    <h1 class="h2">Study Resources</h1>
</div>

<p class="lead">Find study materials, documents, and helpful links related to your courses and general studies.</p>

<div class="row">
    <div class="col-md-8">
        <h4 class="mb-3"><i class="fas fa-book-open me-2 text-primary"></i>Available Materials</h4>
        <% if (studyResources && studyResources.length > 0) { %>
            <div class="list-group shadow-sm">
                <% studyResources.forEach(function(resource) { %>
                    <a href="<%= resource.resource_url %>" class="list-group-item list-group-item-action" target="_blank" rel="noopener noreferrer">
                        <div class="d-flex w-100 justify-content-between">
                            <h5 class="mb-1"><%= resource.title %></h5>
                            <small class="text-muted">Added: <%= new Date(resource.created_at).toLocaleDateString() %></small>
                        </div>
                        <% if (resource.description) { %>
                            <p class="mb-1 text-muted small"><%= resource.description %></p>
                        <% } %>
                        <small class="text-primary"><i class="fas fa-link me-1"></i> View Resource</small>
                    </a>
                <% }); %>
            </div>
        <% } else { %>
            <div class="alert alert-info">
                <i class="fas fa-info-circle me-2"></i>No study resources are currently available. Please check back later.
            </div>
        <% } %>
    </div>

    <div class="col-md-4">
        <div class="card shadow-sm">
            <div class="card-header bg-info text-white">
                <h5 class="mb-0"><i class="fas fa-wifi me-2"></i>Campus Wi-Fi Details</h5>
            </div>
            <div class="card-body">
                <p class="mb-1"><strong>Network Name (SSID):</strong></p>
                <p class="fw-bold fs-5"><%= wifiDetails.ssid %></p>

                <p class="mb-1 mt-3"><strong>Password:</strong></p>
                <p class="fw-bold fs-5"><%= wifiDetails.password %></p>

                <% if (wifiDetails.disclaimer) { %>
                    <hr>
                    <p class="small text-muted mt-3">
                        <strong>Disclaimer:</strong> <%= wifiDetails.disclaimer %>
                    </p>
                <% } %>
            </div>
        </div>
    </div>
</div>

<div class="mt-4">
    <a href="/portals/student/dashboard" class="btn btn-outline-secondary"><i class="fas fa-arrow-left me-1"></i> Back to Dashboard</a>
</div>
