<%# This page is rendered within layouts/student_layout.ejs %>
<%# viewData from the controller is available here %>
<% const eligibleCertificates = viewData.eligibleCertificates; %>
<% const feesCleared = viewData.feesCleared; %>

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="/student/dashboard">Dashboard</a></li>
        <li class="breadcrumb-item active" aria-current="page"><%= viewData.title || 'My Certificates' %></li>
    </ol>
</nav>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h2"><i class="fas fa-certificate text-primary me-2"></i><%= viewData.title || 'My Certificates' %></h1>
</div>
<p class="text-muted">View and download certificates for courses you have successfully completed and for which all fees are cleared.</p>
<hr class="my-4">


<% if (viewData.errorLoading) { %>
    <div class="alert alert-danger" role="alert">
        <h4 class="alert-heading">Error Loading Certificate Information!</h4>
        <p>We encountered an issue trying to load your certificate data. Please try again later.</p>
        <% if (viewData.errorMessage) { %>
            <p class="mb-0"><small>Details: <%= viewData.errorMessage %></small></p>
        <% } %>
    </div>
<% else { %>
    <% if (!feesCleared) { %>
        <div class="alert alert-warning shadow-sm">
            <h4 class="alert-heading"><i class="fas fa-exclamation-triangle me-2"></i>Fee Balance Outstanding</h4>
            <p>You currently have an outstanding fee balance. Certificates can only be downloaded once all fees are cleared.</p>
            <p class="mb-0">Please check your <a href="/student/my-fees" class="alert-link">Fee Statement</a> or contact administration.</p>
        </div>
    <% } %>

    <% if (eligibleCertificates && eligibleCertificates.length > 0) { %>
        <h4 class="mt-4 mb-3">Available Certificates:</h4>
        <div class="row g-4">
            <% eligibleCertificates.forEach(function(cert) { %>
                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 shadow-sm certificate-card <%= cert.is_eligible_for_download ? 'border-success' : 'border-light' %>">
                        <div class="card-body">
                            <h5 class="card-title text-primary"><i class="fas fa-award me-2"></i><%= cert.course_name %></h5>
                            <p class="card-text">
                                <span class="badge bg-success">Status: Passed</span><br>
                                <% if (cert.certificate_issued_at) { %>
                                    <small class="text-muted d-block mt-1">Previously generated: <%= new Date(cert.certificate_issued_at).toLocaleDateString() %></small>
                                <% } %>
                            </p>
                        </div>
                        <div class="card-footer bg-light text-center">
                            <% if (cert.is_eligible_for_download) { %>
                                <a href="/student/certificate/download/<%= cert.enrollment_id %>" class="btn btn-success" target="_blank">
                                    <i class="fas fa-download me-2"></i>Download Certificate
                                </a>
                            <% } else { %>
                                <button class="btn btn-secondary" disabled title="Fee payment pending or other requirements not met">
                                    <i class="fas fa-times-circle me-2"></i>Download Unavailable
                                </button>
                            <% } %>
                        </div>
                    </div>
                </div>
            <% }); %>
        </div>
    <% } else { %>
        <div class="alert alert-info mt-3">
            <i class="fas fa-info-circle me-2"></i>
            You do not currently have any certificates eligible for download.
            This could be because you have not yet passed any courses, or have outstanding fees if courses have been passed.
        </div>
    <% } %>
<% } %>

<div class="mt-4">
    <a href="/student/dashboard" class="btn btn-secondary"><i class="fas fa-arrow-left me-2"></i>Back to Dashboard</a>
</div>

<style>
    .certificate-card {
        transition: transform 0.2s ease-in-out, box-shadow 0.2s ease-in-out;
    }
    .certificate-card:hover {
        transform: translateY(-3px);
        box-shadow: var(--shadow-md) !important;
    }
</style>
