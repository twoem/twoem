<%# This page is rendered within layouts/student_layout.ejs %>
<%# viewData from the controller is available here %>
<% const student = viewData.student; %>
<% const errors = viewData.errors || []; %>
<% const nokName = viewData.nokName; %>
<% const nokRelationship = viewData.nokRelationship; %>
<% const nokPhone = viewData.nokPhone; %>
<% const nokEmail = viewData.nokEmail; %>


<div class="row justify-content-center pt-4">
    <div class="col-md-8 col-lg-7">
        <div class="card shadow-sm">
            <div class="card-header bg-warning text-dark">
                <h1 class="h5 mb-0"><i class="fas fa-user-check me-2"></i><%= viewData.title || 'Complete Your Profile' %></h1>
            </div>
            <div class="card-body">
                 <p class="lead">Welcome, <%= student.firstName %>!</p>
                <p class="text-muted">Please provide your Next of Kin details to complete your profile setup. This information is important in case of emergencies.</p>

                <%- include('../../partials/validation-errors', { errors: errors }) %>
                <%# Flash messages are handled by the layout %>

                <form action="/student/complete-profile-initial" method="POST">
                    <div class="mb-3">
                        <label for="nokName" class="form-label">Next of Kin Full Name <span class="text-danger">*</span></label>
                        <input type="text" class="form-control <%= errors.find(e => e.param === 'nokName') ? 'is-invalid' : '' %>"
                               id="nokName" name="nokName" required value="<%= nokName %>">
                        <% if (errors.find(e => e.param === 'nokName')) { %><div class="invalid-feedback"><%= errors.find(e => e.param === 'nokName').msg %></div><% } %>
                    </div>
                    <div class="mb-3">
                        <label for="nokRelationship" class="form-label">Relationship to You <span class="text-danger">*</span></label>
                        <input type="text" class="form-control <%= errors.find(e => e.param === 'nokRelationship') ? 'is-invalid' : '' %>"
                               id="nokRelationship" name="nokRelationship" required value="<%= nokRelationship %>">
                        <div class="form-text">E.g., Parent, Guardian, Spouse, Sibling, etc.</div>
                        <% if (errors.find(e => e.param === 'nokRelationship')) { %><div class="invalid-feedback"><%= errors.find(e => e.param === 'nokRelationship').msg %></div><% } %>
                    </div>
                    <div class="mb-3">
                        <label for="nokPhone" class="form-label">Next of Kin Phone Number <span class="text-danger">*</span></label>
                        <input type="tel" class="form-control <%= errors.find(e => e.param === 'nokPhone') ? 'is-invalid' : '' %>"
                               id="nokPhone" name="nokPhone" required
                               pattern="^(0[17][0-9]{8})$" title="Phone number must start with 01 or 07 and be 10 digits long."
                               value="<%= nokPhone %>">
                        <div class="form-text">Format: 07XXXXXXXX or 01XXXXXXXX.</div>
                        <% if (errors.find(e => e.param === 'nokPhone')) { %><div class="invalid-feedback"><%= errors.find(e => e.param === 'nokPhone').msg %></div><% } %>
                    </div>
                    <div class="mb-3">
                        <label for="nokEmail" class="form-label">Next of Kin Email (Optional)</label>
                        <input type="email" class="form-control <%= errors.find(e => e.param === 'nokEmail') ? 'is-invalid' : '' %>"
                               id="nokEmail" name="nokEmail" value="<%= nokEmail %>">
                        <% if (errors.find(e => e.param === 'nokEmail')) { %><div class="invalid-feedback"><%= errors.find(e => e.param === 'nokEmail').msg %></div><% } %>
                    </div>

                    <div class="d-grid mt-4">
                        <button type="submit" class="btn btn-primary"><i class="fas fa-save me-2"></i>Save Profile Information</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
