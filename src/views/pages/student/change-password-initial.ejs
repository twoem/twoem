<%# This page is rendered within layouts/student_layout.ejs %>
<%# viewData from the controller is available here %>
<% const defaultStudentPassword = viewData.defaultStudentPassword; %>
<% const passwordMinLength = viewData.passwordMinLength; %>
<% const errors = viewData.errors || []; %>


<div class="row justify-content-center pt-4">
    <div class="col-md-7 col-lg-6">
        <div class="card shadow-sm">
            <div class="card-header bg-warning text-dark">
                <h1 class="h5 mb-0"><i class="fas fa-key me-2"></i><%= viewData.title || 'Change Initial Password' %></h1>
            </div>
            <div class="card-body">
                <p class="lead">Welcome, <%= viewData.student.firstName %>!</p>
                <p class="text-muted">As this is your first time logging in or your password was reset, you must change your password before proceeding.</p>

                <%- include('../../partials/validation-errors', { errors: errors }) %>
                <%# Flash messages are handled by the layout %>

                <form action="/student/change-password-initial" method="POST">
                    <div class="mb-3">
                        <label for="currentPassword" class="form-label">Current Default Password</label>
                        <input type="password" class="form-control <%= errors.find(e => e.param === 'currentPassword') ? 'is-invalid' : '' %>" id="currentPassword" name="currentPassword" required>
                        <div class="form-text">This is the default password that was assigned to you.
                            <% if (defaultStudentPassword) { %> Hint: it's <strong><%= defaultStudentPassword %></strong> <% } %>
                        </div>
                         <% if (errors.find(e => e.param === 'currentPassword')) { %><div class="invalid-feedback"><%= errors.find(e => e.param === 'currentPassword').msg %></div><% } %>
                    </div>
                    <div class="mb-3">
                        <label for="newPassword" class="form-label">New Password</label>
                        <input type="password" class="form-control <%= errors.find(e => e.param === 'newPassword') ? 'is-invalid' : '' %>" id="newPassword" name="newPassword" required minlength="<%= passwordMinLength %>">
                        <div class="form-text">Minimum <%= passwordMinLength %> characters.</div>
                        <% if (errors.find(e => e.param === 'newPassword')) { %><div class="invalid-feedback"><%= errors.find(e => e.param === 'newPassword').msg %></div><% } %>
                    </div>
                    <div class="mb-3">
                        <label for="confirmNewPassword" class="form-label">Confirm New Password</label>
                        <input type="password" class="form-control <%= errors.find(e => e.param === 'confirmNewPassword') ? 'is-invalid' : '' %>" id="confirmNewPassword" name="confirmNewPassword" required>
                        <% if (errors.find(e => e.param === 'confirmNewPassword')) { %><div class="invalid-feedback"><%= errors.find(e => e.param === 'confirmNewPassword').msg %></div><% } %>
                    </div>
                    <div class="d-grid mt-4">
                        <button type="submit" class="btn btn-primary"><i class="fas fa-save me-2"></i>Set New Password</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
