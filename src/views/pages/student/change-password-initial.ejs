<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <link rel="stylesheet" href="/css/style.css">
    <style>
        :root {
            --lavender-lightest-yellow: #FDFBD4;
            --lavender-muted-green: #BDB96A;
            --lavender-light-blue: #C1BFFF;
            --lavender-very-light: #DBD4FF;
            --lavender-vibrant-purple: #CF6DFC;
            --lavender-darker-purple: #a358d3;
        }
        body.page-form-centered {
            display: flex; align-items: center; justify-content: center; min-height: 100vh;
            background-color: var(--lavender-very-light);
            background-image: linear-gradient(135deg, var(--lavender-light-blue) 0%, var(--lavender-very-light) 100%);
            padding: 1rem;
        }
        .form-container {
            background-color: #ffffff; padding: 2rem; border-radius: 0.75rem;
            box-shadow: 0 0.5rem 1.5rem rgba(0,0,0,0.1); width: 100%; max-width: 480px;
        }
        .form-container h3 { color: var(--lavender-darker-purple); font-weight: 600; }
        .btn-submit-form {
            background-color: var(--lavender-vibrant-purple); border-color: var(--lavender-vibrant-purple);
            color: white; font-weight: 500; padding: 0.75rem;
        }
        .btn-submit-form:hover { background-color: var(--lavender-darker-purple); border-color: var(--lavender-darker-purple); }
        .form-control:focus {
            border-color: var(--lavender-vibrant-purple);
            box-shadow: 0 0 0 0.25rem rgba(207, 109, 252, 0.25); /* lavender-vibrant-purple with alpha */
        }
    </style>
</head>
<body class="page-form-centered">
    <div class="form-container">
        <div class="text-center mb-4">
            <a href="https://ibb.co/hF8jSC4H"><img src="https://i.ibb.co/XxJgqVKp/IMG-20250701-WA0003.jpg" alt="IMG-20250701-WA0003" border="0" style="max-height: 80px; margin-bottom: 1rem;"></a>
            <h3>Set Your New Password</h3>
            <p class="text-muted">Welcome! As this is your first time logging in, please change your default password to secure your account.</p>
        </div>

        <%- include('../../partials/flash-messages') %>

        <form action="/portals/student/change-password" method="POST">
            <div class="mb-3">
                <label for="currentPassword" class="form-label">Current Default Password</label>
                <input type="password" class="form-control" id="currentPassword" name="currentPassword" required>
                <% if (locals.defaultStudentPassword) { %>
                    <div class="form-text text-info">Hint: The default password is <strong><%= defaultStudentPassword %></strong></div>
                <% } %>
            </div>
            <div class="mb-3">
                <label for="newPassword" class="form-label">New Password</label>
                <input type="password" class="form-control" id="newPassword" name="newPassword" required minlength="<%= locals.passwordMinLength || 8 %>">
                <div class="form-text">
                    Must be at least <%= locals.passwordMinLength || 8 %> characters long.
                </div>
            </div>
            <div class="mb-3">
                <label for="confirmNewPassword" class="form-label">Confirm New Password</label>
                <input type="password" class="form-control" id="confirmNewPassword" name="confirmNewPassword" required>
            </div>
            <div class="d-grid mt-4">
                <button type="submit" class="btn btn-submit-form w-100"><i class="fas fa-key me-2"></i>Set New Password</button>
            </div>
        </form>
        <div class="mt-4 text-center">
             <small class="text-muted">If you encounter issues, please contact support.</small>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
