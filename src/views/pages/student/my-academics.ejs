<% /* This page is rendered within layouts/portal-student.ejs */ %>
<% /* Flash messages are handled by the layout */ %>

<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
    <h1 class="h2">My Academics - <%= courseName %></h1>
    <span class="text-muted small">Passing Grade: <%= PASSING_GRADE %>%</span>
</div>

<% if (motivationalMessage) { %>
    <div class="alert alert-info" style="background-color: var(--lavender-very-light); border-color: var(--lavender-light-blue); color: var(--lavender-darker-purple);">
        <i class="fas fa-lightbulb me-2"></i><%= motivationalMessage %>
    </div>
<% } %>

<% if (academicMessage && (courseStatus !== 'ongoing' || overallGrade === 'Incomplete') ) { %>
    <div class="alert <%= overallGrade === 'Incomplete' || courseStatus === 'failed' ? 'alert-danger' : 'alert-warning' %>">
        <%= academicMessage %>
    </div>
<% } %>


<% if (courseStatus === 'not_enrolled') { %>
    <div class="alert alert-warning">
        You are not currently enrolled in this course, or academic records are not yet available.
    </div>
<% } else { %>
    <div class="row">
        <!-- Marks Details Column -->
        <div class="col-lg-8">
            <h4 class="fw-bold mb-3" style="color: var(--lavender-darker-purple);">Unit Marks (Contributes 30% to Final Grade)</h4>
            <div class="table-responsive card shadow-sm mb-4" style="border-radius: 0.5rem;">
                <table class="table table-bordered table-hover mb-0">
                    <thead style="background-color: var(--lavender-very-light);">
                        <tr>
                            <th style="color: var(--lavender-darker-purple);">Unit Name</th>
                            <th class="text-center" style="color: var(--lavender-darker-purple);">Marks Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% units.forEach(unit => { %>
                            <tr>
                                <td><%= unit.name %></td>
                                <td class="text-center <%= unit.status === 'Not Tested' ? 'text-muted fst-italic' : (unit.marks !== null && unit.marks < (unit.maxMarks * PASSING_GRADE / 100) ? 'text-danger fw-bold' : 'text-success') %>">
                                    <%= unit.status %>
                                </td>
                            </tr>
                        <% }); %>
                    </tbody>
                    <% if (unitsRawTotal !== null) { %>
                        <tfoot>
                            <tr class="table-secondary">
                                <td class="fw-bold text-end">Units Raw Total:</td>
                                <td class="text-center fw-bold"><%= unitsRawTotal %> / <%= units.reduce((sum, unit) => sum + unit.maxMarks, 0) %></td>
                            </tr>
                        </tfoot>
                    <% } %>
                </table>
            </div>

            <h4 class="fw-bold mt-4 mb-3" style="color: var(--lavender-darker-purple);">Exam Marks</h4>
            <div class="table-responsive card shadow-sm" style="border-radius: 0.5rem;">
                <table class="table table-bordered table-hover mb-0">
                    <thead style="background-color: var(--lavender-very-light);">
                        <tr>
                            <th style="color: var(--lavender-darker-purple);">Exam Component</th>
                            <th class="text-center" style="color: var(--lavender-darker-purple);">Marks Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% exams.forEach(exam => { %>
                            <tr>
                                <td><%= exam.name %></td>
                                <td class="text-center <%= exam.status === 'Not Tested' ? 'text-muted fst-italic' : (exam.marks !== null && exam.marks < (exam.maxMarks * PASSING_GRADE / 100) ? 'text-danger fw-bold' : 'text-success') %>">
                                    <%= exam.status %>
                                </td>
                            </tr>
                        <% }); %>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Summary Column -->
        <div class="col-lg-4">
            <div class="card shadow-sm" style="border-radius: 0.75rem; background-color: var(--lavender-lightest-yellow);">
                <div class="card-header" style="background-color: var(--lavender-very-light); border-bottom: 1px solid var(--lavender-light-blue);">
                    <h5 class="mb-0 fw-bold" style="color: var(--lavender-darker-purple);"><i class="fas fa-poll-h me-2"></i>Overall Summary</h5>
                </div>
                <ul class="list-group list-group-flush" style="border-radius: 0 0 0.75rem 0.75rem;">
                    <li class="list-group-item" style="background-color: var(--lavender-lightest-yellow);">
                        <strong>Course Status:</strong>
                        <span class="fw-bold text-capitalize
                            <% if (courseStatus === 'completed') { %>text-success<% } %>
                            <% else if (courseStatus === 'failed' || courseStatus === 'incomplete' || overallGrade === 'Incomplete') { %>text-danger<% } %>
                            <% else if (courseStatus === 'ongoing') { %>text-info<% } %>
                            <% else { %>text-muted<% } %>">
                            <%= courseStatus.replace('_', ' ') %>
                        </span>
                    </li>
                    <li class="list-group-item" style="background-color: var(--lavender-lightest-yellow);">
                        <strong>Units Contribution (30%):</strong>
                        <span class="fw-bold"><%= unitsContribution.toFixed(2) %>%</span>
                    </li>
                    <li class="list-group-item" style="background-color: var(--lavender-lightest-yellow);">
                        <strong>Theory Exam (35%):</strong>
                        <span class="fw-bold"><%= theoryContribution.toFixed(2) %>%</span>
                    </li>
                    <li class="list-group-item" style="background-color: var(--lavender-lightest-yellow);">
                        <strong>Practical Exam (35%):</strong>
                        <span class="fw-bold"><%= practicalContribution.toFixed(2) %>%</span>
                    </li>
                    <li class="list-group-item" style="background-color: var(--lavender-very-light); border-top: 2px solid var(--lavender-light-blue);">
                        <strong class="h5" style="color: var(--lavender-darker-purple);">Overall Percentage:</strong>
                        <span class="h5 fw-bold <%= finalGradePercent < PASSING_GRADE ? 'text-danger' : 'text-success' %>">
                            <%= finalGradePercent %>%
                        </span>
                    </li>
                    <li class="list-group-item" style="background-color: var(--lavender-very-light);">
                        <strong class="h5" style="color: var(--lavender-darker-purple);">Final Grade:</strong>
                        <span class="h5 fw-bold text-capitalize
                            <% if (overallGrade === 'Distinction' || overallGrade === 'Credit' || overallGrade === 'Pass') { %>text-success<% } %>
                            <% else if (overallGrade === 'Fail' || overallGrade === 'Incomplete') { %>text-danger<% } %>
                            <% else { %>text-info<% } %>">
                            <%= overallGrade %>
                        </span>
                    </li>
                     <% if (examScheduleDate) { %>
                        <li class="list-group-item list-group-item-info mt-2">
                            <strong><i class="fas fa-calendar-check me-2"></i>Main Exam Scheduled:</strong>
                            <span class="fw-bold"><%= new Date(examScheduleDate).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric', hour: '2-digit', minute: '2-digit' }) %></span>
                        </li>
                    <% } else if (courseStatus === 'ongoing') { %>
                         <li class="list-group-item list-group-item-warning mt-2">
                            <strong><i class="fas fa-calendar-alt me-2"></i>Main Exam:</strong>
                            <span class="fw-bold">Not Yet Scheduled</span>
                        </li>
                    <% } %>
                </ul>
            </div>
        </div>
    </div>
<% } %>
