<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
    <style>
        body {
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            background-color: #f8f9fa;
        }
        .reset-container {
            background-color: #fff;
            padding: 2rem;
            border-radius: 0.5rem;
            box-shadow: 0 0.5rem 1rem rgba(0,0,0,0.15);
            width: 100%;
            max-width: 450px;
        }
    </style>
</head>
<body>
    <div class="reset-container">
        <div class="text-center mb-4">
            <img src="/logo.png" alt="Logo" style="max-width: 100px; margin-bottom: 1rem;">
            <h3>Set New Password</h3>
            <p class="text-muted">Your reset token is valid. Please enter your new password below.</p>
        </div>

        <%- include('../../partials/flash-messages') %>

        <% if (typeof tokenValid === 'undefined' || tokenValid) { %> <!-- Only show form if token is valid -->
            <form action="/student/reset-password-with-token/<%= urlToken %>" method="POST">
                <input type="hidden" name="urlToken" value="<%= urlToken %>"> <!-- Pass token for POST -->

                <div class="mb-3">
                    <label for="newPassword" class="form-label">New Password</label>
                    <input type="password" class="form-control" id="newPassword" name="newPassword" required
                           minlength="<%= passwordMinLength || 8 %>">
                    <div class="form-text">
                        Must be at least <%= passwordMinLength || 8 %> characters long.
                    </div>
                </div>
                <div class="mb-3">
                    <label for="confirmNewPassword" class="form-label">Confirm New Password</label>
                    <input type="password" class="form-control" id="confirmNewPassword" name="confirmNewPassword" required>
                </div>
                <div class="d-grid">
                    <button type="submit" class="btn btn-primary">Set New Password</button>
                </div>
            </form>
        <% } else { %>
            <!-- Message for invalid/expired token already handled by controller redirecting with flash,
                 but this is a fallback if somehow landed here with invalid state. -->
            <div class="alert alert-danger">
                The password reset link is invalid or has expired. Please try requesting a new one.
            </div>
        <% } %>
        <div class="mt-3 text-center">
            <a href="/student/login">Back to Login</a>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
