<%# This page is rendered within layouts/student_layout.ejs %>
<%# viewData from the controller is available here %>
<% const wifi_ssid = viewData.wifi_ssid; %>
<% const wifi_password = viewData.wifi_password; %>
<% const wifi_disclaimer = viewData.wifi_disclaimer; %>


<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="/student/dashboard">Dashboard</a></li>
        <li class="breadcrumb-item active" aria-current="page"><%= viewData.title || 'WiFi Credentials' %></li>
    </ol>
</nav>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h2"><i class="fas fa-wifi text-primary me-2"></i><%= viewData.title || 'WiFi Access Information' %></h1>
</div>
<hr class="my-4">


<% if (viewData.errorLoading) { %>
    <div class="alert alert-danger" role="alert">
        <h4 class="alert-heading">Error Loading WiFi Information!</h4>
        <p>We encountered an issue trying to load the WiFi details. Please try again later.</p>
        <% if (viewData.errorMessage) { %>
            <p class="mb-0"><small>Details: <%= viewData.errorMessage %></small></p>
        <% } %>
    </div>
<% else { %>
    <div class="card shadow-sm">
        <div class="card-header bg-light">
            <h4 class="h5 mb-0">Current Network Details</h4>
        </div>
        <div class="card-body">
            <% if (wifi_ssid && wifi_ssid !== 'Not Set by Admin' && wifi_ssid !== 'Error') { %>
                <dl class="row">
                    <dt class="col-sm-4 col-md-3">Network Name (SSID):</dt>
                    <dd class="col-sm-8 col-md-9"><h3><span class="badge bg-info text-dark"><%= wifi_ssid %></span></h3></dd>

                    <dt class="col-sm-4 col-md-3">Password:</dt>
                    <dd class="col-sm-8 col-md-9">
                        <% if (wifi_password && wifi_password !== 'Not Set by Admin') { %>
                            <div class="input-group" style="max-width: 300px;">
                                <input type="password" class="form-control" id="wifiPasswordDisplay" value="<%= wifi_password %>" readonly>
                                <button class="btn btn-outline-secondary" type="button" id="toggleStudentWifiPassVisibility" title="Show/Hide Password">
                                    <i class="fas fa-eye" id="studentWifiEyeIcon"></i>
                                </button>
                            </div>
                        <% } else { %>
                            <span class="text-muted fst-italic">Not Set by Admin</span>
                        <% } %>
                    </dd>
                </dl>
                <% if (wifi_disclaimer) { %>
                    <h5 class="mt-4">Usage Policy & Disclaimer:</h5>
                    <div class="p-3 bg-light border rounded" style="white-space: pre-wrap;"><%= wifi_disclaimer %></div>
                <% } %>
            <% } else if (wifi_ssid === 'Error') { %>
                 <div class="alert alert-warning">Could not load WiFi details at this moment.</div>
            <% } else { %>
                <div class="alert alert-info">WiFi details have not been configured by the administrator yet. Please check back later.</div>
            <% } %>
        </div>
    </div>
<% } %>

<div class="mt-4">
    <a href="/student/dashboard" class="btn btn-secondary"><i class="fas fa-arrow-left me-2"></i>Back to Dashboard</a>
</div>

<% if (wifi_ssid && wifi_ssid !== 'Not Set by Admin' && wifi_password && wifi_password !== 'Not Set by Admin' && wifi_ssid !== 'Error') { %>
<script>
    document.addEventListener('DOMContentLoaded', function () {
        const toggleButton = document.getElementById('toggleStudentWifiPassVisibility');
        const passwordDisplay = document.getElementById('wifiPasswordDisplay');
        const eyeIcon = document.getElementById('studentWifiEyeIcon');

        if (toggleButton && passwordDisplay && eyeIcon) {
            toggleButton.addEventListener('click', function () {
                if (passwordDisplay.getAttribute('type') === 'password') {
                    passwordDisplay.setAttribute('type', 'text');
                    eyeIcon.classList.remove('fa-eye');
                    eyeIcon.classList.add('fa-eye-slash');
                } else {
                    passwordDisplay.setAttribute('type', 'password');
                    eyeIcon.classList.remove('fa-eye-slash');
                    eyeIcon.classList.add('fa-eye');
                }
            });
        }
    });
</script>
<% } %>
