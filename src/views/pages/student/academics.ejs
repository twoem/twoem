<%- include('../../partials/header', { title: title }) %>
<%- include('../../partials/navbar') %>

<main class="container mt-5">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/student/dashboard">Dashboard</a></li>
            <li class="breadcrumb-item active" aria-current="page">My Academic Records</li>
        </ol>
    </nav>

    <h2 class="mb-3">My Academic Records</h2>

    <% if (studentDetails) { %>
        <p class="lead">Hello, <strong><%= studentDetails.first_name %> <%= studentDetails.second_name || '' %> <%= studentDetails.surname || '' %></strong>. Here are your academic details for <%= courseName %>.</p>
    <% } %>

    <p>Unit marks contribute 30% and Exam marks (Theory & Practical average) contribute 70% to the final grade.</p>
    <hr>

    <% if (locals.error_msg) { %><div class="alert alert-danger"><%= error_msg %></div><% } %>
    <% if (locals.info_msg) { %><div class="alert alert-info"><%= info_msg %></div><% } %>
    <% if (locals.success_msg) { %><div class="alert alert-success"><%= success_msg %></div><% } %>


    <% if (errorMsg) { %>
        <div class="alert alert-warning"><%= errorMsg %></div>
    <% } else if (courseName !== 'N/A' && unitsWithMarks) { %>
        <div class="card shadow-sm mb-4">
            <div class="card-header bg-light">
                <h4 class="h5 mb-0">Course: <%= courseName %></h4>
            </div>
            <div class="card-body">
                <h5 class="card-title">Unit Marks</h5>
                <% if (unitsWithMarks.length > 0) { %>
                    <div class="table-responsive mb-3">
                        <table class="table table-sm table-bordered">
                            <thead class="table-light">
                                <tr>
                                    <th>Unit Name</th>
                                    <th class="text-center">Marks Obtained</th>
                                    <th class="text-center">Max Marks</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% unitsWithMarks.forEach(unit => { %>
                                    <tr>
                                        <td><%= unit.unit_name %></td>
                                        <td class="text-center"><%= unit.marks_obtained !== null && unit.marks_obtained !== undefined ? unit.marks_obtained : '{Pending}' %></td>
                                        <td class="text-center"><%= unit.max_marks %></td>
                                    </tr>
                                <% }); %>
                            </tbody>
                        </table>
                    </div>
                <% } else { %>
                    <p class="text-muted">Unit details for this course are not yet available.</p>
                <% } %>

                <h5 class="card-title mt-4">Exam Marks</h5>
                <div class="row">
                    <div class="col-md-6">
                        <p><strong>Theory Exam:</strong> <%= examMarks.theory !== null && examMarks.theory !== undefined ? examMarks.theory : '{Pending}' %> / 100</p>
                    </div>
                    <div class="col-md-6">
                        <p><strong>Practical Exam:</strong> <%= examMarks.practical !== null && examMarks.practical !== undefined ? examMarks.practical : '{Pending}' %> / 100</p>
                    </div>
                </div>

                <h5 class="card-title mt-4">Summary</h5>
                <p><strong>Overall Final Grade:</strong>
                    <span class="badge fs-6 <%= finalGrade === 'Pass' || finalGrade === 'Credit' || finalGrade === 'Distinction' ? 'bg-success' : (finalGrade === 'Fail' ? 'bg-danger' : 'bg-secondary') %>">
                        <%= finalGrade || '{Pending}' %>
                    </span>
                </p>
                <p><strong>Completion Status:</strong>
                    <span class="badge fs-6 <%= completionStatus === 'Completed' ? 'bg-success' : (completionStatus === 'Incomplete' ? 'bg-warning text-dark' : 'bg-secondary') %>">
                        <%= completionStatus || '{Pending}' %>
                    </span>
                </p>
            </div>
        </div>
    <% } else if (!info_msg) { %>
        <div class="alert alert-info">
            Your academic records for "Computer Classes" are not yet available or you are not enrolled.
        </div>
    <% } %>


    <div class="mt-4">
        <a href="/student/dashboard" class="btn btn-secondary"><i class="fas fa-arrow-left"></i> Back to Dashboard</a>
    </div>
</main>

<%- include('../../partials/footer') %>
