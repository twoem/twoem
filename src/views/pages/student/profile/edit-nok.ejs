<%- include('../../../partials/studentHeader', { title: title, student: student }) %>

    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/student/dashboard">Dashboard</a></li>
            <li class="breadcrumb-item active" aria-current="page">Update Next of Kin</li>
        </ol>
    </nav>

    <div class="row justify-content-center">
        <div class="col-md-7 col-lg-6">
            <div class="card shadow-lg" style="border-radius: 0.75rem;">
                <div class="card-header text-white" style="background-color: var(--lavender-darker-purple); border-top-left-radius: 0.75rem; border-top-right-radius: 0.75rem;">
                    <h4 class="mb-0"><i class="fas fa-users me-2"></i>Update Next of Kin Information</h4>
                </div>
                <div class="card-body" style="background-color: var(--lavender-lightest-yellow);">
                    <p class="text-muted">Keep your Next of Kin details up-to-date for emergency purposes.</p>

                    <%- include('../../../partials/flash-messages') %>

                    <form action="/student/profile/edit-nok" method="POST">
                        <div class="mb-3">
                            <label for="nokName" class="form-label">Next of Kin Full Name <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" id="nokName" name="nokName" required
                                   value="<%= locals.nokName !== undefined ? locals.nokName : (currentNokDetails ? currentNokDetails.name : '') %>">
                        </div>
                        <div class="mb-3">
                            <label for="nokRelationship" class="form-label">Relationship to You</label>
                            <input type="text" class="form-control" id="nokRelationship" name="nokRelationship" required
                                   value="<%= locals.nokRelationship !== undefined ? locals.nokRelationship : (currentNokDetails ? currentNokDetails.relationship : '') %>">
                             <div class="form-text">E.g., Parent, Guardian, Spouse, Sibling, etc.</div>
                        </div>
                        <div class="mb-3">
                            <label for="nokPhone" class="form-label">Next of Kin Phone Number</label>
                            <input type="tel" class="form-control" id="nokPhone" name="nokPhone" required
                                   value="<%= locals.nokPhone !== undefined ? locals.nokPhone : (currentNokDetails ? currentNokDetails.phone : '') %>">
                        </div>
                        <div class="mb-3">
                            <label for="nokEmail" class="form-label">Next of Kin Email (Optional)</label>
                            <input type="email" class="form-control" id="nokEmail" name="nokEmail"
                                   value="<%= locals.nokEmail !== undefined ? locals.nokEmail : (currentNokDetails ? currentNokDetails.email : '') %>">
                        </div>

                        <div class="d-grid mt-4">
                            <button type="submit" class="btn w-100" style="background-color: var(--lavender-vibrant-purple); color:white;"><i class="fas fa-save me-2"></i>Save Changes</button>
                        </div>
                    </form>
                     <div class="text-center mt-3">
                        <a href="/student/dashboard" class="btn btn-sm btn-outline-secondary" style="border-color: var(--lavender-muted-green); color: var(--lavender-muted-green);">
                            <i class="fas fa-arrow-left me-1"></i> Back to Dashboard
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>

<%- include('../../../partials/studentFooter') %>
