<% /* This page is rendered within layouts/portal-student.ejs */ %>
<% /* Flash messages are handled by the layout */ %>

<div class="row">
    <div class="col-12">
        <div class="card shadow-sm mb-4 bg-light">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h2 class="mb-0">Hello, <strong class="text-primary"><%= student.first_name %></strong>!</h2>
                        <p class="lead mb-0 text-muted">Welcome back, we've missed you!</p>
                    </div>
                    <div class="text-end">
                        <p class="mb-0 small"><i class="fas fa-calendar-alt me-1"></i> <%= currentDate.toLocaleDateString('en-US', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' }) %></p>
                        <p class="mb-0 small"><i class="fas fa-clock me-1"></i> <span id="currentTime"></span></p>
                         <% if (student.last_login_at) { %>
                            <p class="mb-0 small text-muted"><i class="fas fa-history me-1"></i> Last Login: <%= new Date(student.last_login_at).toLocaleString() %></p>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <!-- Student Information Column -->
    <div class="col-lg-7 mb-4">
        <div class="card shadow-sm h-100">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0"><i class="fas fa-id-card me-2"></i>Your Information</h5>
            </div>
            <div class="card-body">
                <dl class="row">
                    <dt class="col-sm-4">Full Name:</dt>
                    <dd class="col-sm-8"><%= student.first_name %> <%= student.second_name ? student.second_name + ' ' : '' %><%= student.surname %></dd>

                    <dt class="col-sm-4">Registration No:</dt>
                    <dd class="col-sm-8"><%= student.registration_number %></dd>

                    <dt class="col-sm-4">Email Address:</dt>
                    <dd class="col-sm-8"><%= student.email %></dd>

                    <dt class="col-sm-4">Phone Number:</dt>
                    <dd class="col-sm-8"><%= student.phone_number %></dd>

                    <dt class="col-sm-4">Enrolled On:</dt>
                    <dd class="col-sm-8"><%= student.enrolled_date ? new Date(student.enrolled_date).toLocaleDateString() : 'N/A' %></dd>

                    <dt class="col-sm-4">Time Studied:</dt>
                    <dd class="col-sm-8"><%= timeStudied %></dd>

                    <dt class="col-sm-4">Fees Balance:</dt>
                    <dd class="col-sm-8 fw-bold <%= feesBalance <= 0 ? 'text-success' : 'text-danger' %>">
                        KES <%= feesBalance ? feesBalance.toFixed(2) : '0.00' %>
                    </dd>

                    <dt class="col-sm-4">Next of Kin:</dt>
                    <dd class="col-sm-8">
                        <% if (student.next_of_kin_details) { %>
                            <%= student.next_of_kin_details %>
                        <% } else { %>
                            <span class="text-muted">Not set.</span>
                        <% } %>
                        <% if (nokNeedsUpdate) { %>
                            <a href="/portals/student/profile/edit-nok" class="ms-2 badge bg-warning text-dark text-decoration-none">Update Now</a>
                        <% } %>
                    </dd>
                </dl>
                 <a href="/portals/student/profile" class="btn btn-sm btn-outline-primary mt-2"><i class="fas fa-user-edit me-1"></i> View/Edit Profile</a>
            </div>
        </div>
    </div>

    <!-- Notifications & Quick Links Column -->
    <div class="col-lg-5 mb-4">
        <div class="card shadow-sm h-100">
            <div class="card-header bg-info text-white">
                <h5 class="mb-0"><i class="fas fa-bell me-2"></i>Notifications</h5>
            </div>
            <div class="card-body">
                <% if (notifications && notifications.length > 0) { %>
                    <% notifications.forEach(notification => { %>
                        <div class="alert alert-light border-start border-info border-3 mb-2">
                            <h6 class="alert-heading mb-0"><%= notification.title %></h6>
                            <p class="mb-0 small"><%= notification.message %></p>
                            <small class="text-muted"><%= new Date(notification.date).toLocaleDateString() %></small>
                        </div>
                    <% }); %>
                <% } else { %>
                    <p class="text-muted">You have no new notifications.</p>
                <% } %>
            </div>
        </div>
    </div>
</div>

<script>
    function updateTime() {
        const timeElement = document.getElementById('currentTime');
        if (timeElement) {
            timeElement.innerText = new Date().toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit', second: '2-digit', hour12: true });
        }
    }
    setInterval(updateTime, 1000);
    updateTime(); // Initial call
</script>
