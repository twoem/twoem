<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
    <style>
        body {
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            background-color: #f8f9fa;
        }
        .forgot-password-container {
            background-color: #fff;
            padding: 2rem;
            border-radius: 0.5rem;
            box-shadow: 0 0.5rem 1rem rgba(0,0,0,0.15);
            width: 100%;
            max-width: 450px;
        }
    </style>
</head>
<body>
    <div class="forgot-password-container">
        <div class="text-center mb-4">
            <a href="https://ibb.co/hF8jSC4H"><img src="https://i.ibb.co/XxJgqVKp/IMG-20250701-WA0003.jpg" alt="IMG-20250701-WA0003" border="0" style="max-height: 80px; margin-bottom: 1rem;"></a>
            <h3>Forgot Your Password?</h3>
            <p class="text-muted">Enter your registered phone number and any of your names (first, second, or last) to receive a password reset link and OTP.</p>
        </div>

        <% if (messages && messages.error) { %>
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <%- messages.error %>
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        <% } %>
        <% if (messages && messages.success) { %>
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <%- messages.success %>
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        <% } %>

        <form action="/portal/customer/forgot-password" method="POST">
            <div class="mb-3">
                <label for="phoneNumber" class="form-label">Registered Phone Number (07... or 01...)</label>
                <input type="tel" class="form-control" id="phoneNumber" name="phoneNumber"
                       value="<%= formData && formData.phoneNumber ? formData.phoneNumber : '' %>"
                       pattern="^(0[17])\d{8}$" title="Phone number must be 10 digits and start with 01 or 07." required>
            </div>
            <div class="mb-3">
                <label for="anyName" class="form-label">Any Registered Name (First, Second, or Last)</label>
                <input type="text" class="form-control" id="anyName" name="anyName"
                       value="<%= formData && formData.anyName ? formData.anyName : '' %>"
                       required>
            </div>
            <div class="d-grid">
                <button type="submit" class="btn btn-primary">Send Reset Instructions</button>
            </div>
        </form>
        <div class="mt-3 text-center">
            <a href="/portal/customer/login">Back to Login</a>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
