<%- include('../../partials/customerHeader', { title: title, customer: customer }) %>

<% /* Using the container from customerHeader.ejs which has py-4 */ %>
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-7">
            <div class="card shadow-lg" style="border: none; border-radius: 0.75rem;">
                <div class="card-header text-white" style="background-color: var(--lavender-darker-purple); border-top-left-radius: 0.75rem; border-top-right-radius: 0.75rem;">
                    <h4 class="mb-0"><i class="fas fa-user-edit me-2"></i>Update Your Profile</h4>
                </div>
                <div class="card-body" style="background-color: var(--lavender-lightest-yellow);">
                    <%- include('../../partials/flash-messages') %>

                    <form action="/portal/customer/profile/edit" method="POST">
                        <div class="mb-3">
                            <label for="firstName" class="form-label">First Name</label>
                            <input type="text" class="form-control" id="firstName" name="firstName" value="<%= customer.firstName %>" readonly disabled>
                        </div>
                        <div class="mb-3">
                            <label for="lastName" class="form-label">Last Name</label>
                            <input type="text" class="form-control" id="lastName" name="lastName" value="<%= customer.lastName %>" readonly disabled>
                        </div>
                         <% if (customer.organisationName) { %>
                            <div class="mb-3">
                                <label for="organisationName" class="form-label">Organisation Name</label>
                                <input type="text" class="form-control" id="organisationName" name="organisationName" value="<%= customer.organisationName %>" readonly disabled>
                            </div>
                        <% } %>
                        <div class="mb-3">
                            <label for="accountNumber" class="form-label">Account Number</label>
                            <input type="text" class="form-control" id="accountNumber" name="accountNumber" value="<%= customer.accountNumber %>" readonly disabled>
                        </div>

                        <hr>
                        <p class="text-muted">You can update the following details:</p>

                        <div class="mb-3">
                            <label for="email" class="form-label">Email Address <span class="text-danger">*</span></label>
                            <input type="email" class="form-control" id="email" name="email" value="<%= formData && formData.email ? formData.email : customer.email %>" required>
                        </div>

                        <div class="mb-3">
                            <label for="phoneNumber" class="form-label">Phone Number (07... or 01...) <span class="text-danger">*</span></label>
                            <input type="tel" class="form-control" id="phoneNumber" name="phoneNumber"
                                   value="<%= formData && formData.phoneNumber ? formData.phoneNumber : customer.phoneNumber %>"
                                   pattern="^(0[17])\d{8}$" title="Phone number must be 10 digits and start with 01 or 07." required>
                        </div>

                        <div class="mb-3">
                            <label for="location" class="form-label">Location <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" id="location" name="location" value="<%= formData && formData.location ? formData.location : customer.location %>" required>
                        </div>

                        <div class="d-flex justify-content-between mt-4">
                            <a href="/portal/customer/dashboard" class="btn btn-outline-secondary" style="border-color: var(--lavender-muted-green); color: var(--lavender-muted-green);"><i class="fas fa-arrow-left me-1"></i> Back to Dashboard</a>
                            <button type="submit" class="btn" style="background-color: var(--lavender-vibrant-purple); color: white;"><i class="fas fa-save me-2"></i>Save Changes</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
<% /* Container div from customerHeader is closed in customerFooter */ %>
<%- include('../../partials/customerFooter') %>
