<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <link rel="stylesheet" href="/css/style.css">  <!-- Main site style -->
    <style>
        :root {
            --lavender-lightest-yellow: #FDFBD4;
            --lavender-muted-green: #BDB96A;
            --lavender-light-blue: #C1BFFF;
            --lavender-very-light: #DBD4FF;
            --lavender-vibrant-purple: #CF6DFC;
            --lavender-darker-purple: #a358d3; /* Derived for contrast */
            --lavender-nav-text: #343a40;
        }
        body.login-page { /* Specific class for login page body */
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            background-color: var(--lavender-very-light); /* Light Lavender background */
            background-image: linear-gradient(135deg, var(--lavender-light-blue) 0%, var(--lavender-very-light) 100%);
        }
        .login-container {
            background-color: #ffffff; /* White container for contrast */
            padding: 2rem;
            border-radius: 0.5rem;
            box-shadow: 0 0.5rem 1rem rgba(0,0,0,0.15);
            width: 100%;
            max-width: 420px;
        }
        .login-container h3 {
            color: var(--lavender-darker-purple);
            font-weight: 600;
        }
        .btn-login {
            background-color: var(--lavender-vibrant-purple);
            border-color: var(--lavender-vibrant-purple);
            color: white;
            font-weight: 500;
            padding: 0.75rem;
        }
        .btn-login:hover {
            background-color: var(--lavender-darker-purple);
            border-color: var(--lavender-darker-purple);
        }
        .form-control:focus {
            border-color: var(--lavender-light-blue);
            box-shadow: 0 0 0 0.25rem var(--lavender-very-light);
        }
        .login-container a {
            color: var(--lavender-darker-purple);
        }
         .login-container a:hover {
            color: var(--lavender-vibrant-purple);
        }
    </style>
</head>
<body class="login-page">
    <div class="login-container">
        <div class="text-center mb-4">
            <a href="https://ibb.co/hF8jSC4H"><img src="https://i.ibb.co/XxJgqVKp/IMG-20250701-WA0003.jpg" alt="IMG-20250701-WA0003" border="0" style="max-height: 80px; margin-bottom: 1rem;"></a>
            <h3>Customer Portal Login</h3>
        </div>

        <% if (messages && messages.error) { %>
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <%- messages.error %> <% /* Allow HTML in error messages */ %>
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        <% } %>
        <% if (messages && messages.success) { %>
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <%= messages.success %>
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        <% } %>

        <form action="/portals/customer/login" method="POST">
            <div class="mb-3">
                <label for="loginIdentifier" class="form-label">Email / Phone / Account Number</label>
                <input type="text" class="form-control" id="loginIdentifier" name="loginIdentifier" required
                       value="<%= typeof formData !== 'undefined' && formData.loginIdentifier ? formData.loginIdentifier : '' %>">
            </div>
            <div class="mb-3">
                <label for="password" class="form-label">Password</label>
                <input type="password" class="form-control" id="password" name="password" required>
            </div>
            <div class="d-grid">
                <button type="submit" class="btn btn-login w-100"><i class="fas fa-sign-in-alt me-2"></i>Login</button>
            </div>
        </form>
        <div class="mt-4 text-center">
            <a href="/portal/customer/forgot-password">Forgot Password?</a>
        </div>
        <div class="mt-2 text-center">
            <small><a href="/"><i class="fas fa-arrow-left me-1"></i>Back to Main Website</a></small>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
