<%- include('../../partials/customerHeader', { title: title, customer: customer }) %>

<% /* Main container is opened in customerHeader.ejs and closed in customerFooter.ejs */ %>
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-7">
            <div class="card shadow-lg" style="border-radius: 0.75rem;">
                <div class="card-header text-white" style="background-color: var(--lavender-vibrant-purple); border-top-left-radius: 0.75rem; border-top-right-radius: 0.75rem;">
                    <h4 class="mb-0"><i class="fas fa-credit-card me-2"></i>Make a Payment</h4>
                </div>
                <div class="card-body" style="background-color: var(--lavender-lightest-yellow);">
                    <%- include('../../partials/flash-messages') %>

                    <h5 class="fw-bold" style="color: var(--lavender-darker-purple);">Mpesa Payment Instructions:</h5>
                    <div class="alert mt-3" style="background-color: var(--lavender-very-light); border-left: 5px solid var(--lavender-vibrant-purple);">
                        <p class="mb-1"><strong>1. Go to Mpesa App / *334# / SIM Toolkit</strong></p>
                        <p class="mb-1"><strong>2. Select Lipa na Mpesa</strong></p>
                        <p class="mb-1"><strong>3. Select Paybill</strong></p>
                        <p class="mb-1"><strong>4. Enter Business Number:</strong> <strong class="text-danger"><%= BUSINESS_NO ? BUSINESS_NO : 'NOT_CONFIGURED' %></strong></p>
                        <p class="mb-0"><strong>5. Enter Account Number:</strong> <strong class="text-danger"><%= customer.accountNumber %></strong></p>
                        <p class="mt-2">After making the payment, please submit the Mpesa transaction code/message below for verification.</p>
                    </div>

                    <hr style="border-color: var(--lavender-light-blue); border-width: 2px;">

                    <h5 class="fw-bold mt-4" style="color: var(--lavender-darker-purple);">Submit Your Mpesa Transaction Code:</h5>
                    <form action="/portal/customer/pay/submit-code" method="POST">
                        <div class="mb-3">
                            <label for="transactionCode" class="form-label">Mpesa Transaction Code / Message <span class="text-danger">*</span></label>
                            <textarea class="form-control" id="transactionCode" name="transactionCode" rows="3" required placeholder="Enter the full Mpesa confirmation message or just the transaction code (e.g., RFH7GXXXXX)" style="background-color: white; border-color: var(--lavender-light-blue);"><%= formData && formData.transactionCode ? formData.transactionCode : '' %></textarea>
                            <div class="form-text" style="color: var(--lavender-muted-green);">Please enter the Mpesa code (e.g., RFH7GXXXXX) or the full confirmation message you received.</div>
                        </div>

                        <div class="alert alert-warning small" style="background-color: #FFF3CD; border-color: #FFEEBA; color: #664D03;">
                            <strong>Note:</strong> Submitting this form notifies our team to verify your payment. Your account balance will be updated once the payment is confirmed by an administrator. This might take some time.
                        </div>

                        <div class="d-flex justify-content-between mt-4">
                            <a href="/portal/customer/subscription" class="btn btn-outline-secondary" style="border-color: var(--lavender-muted-green); color: var(--lavender-muted-green);"><i class="fas fa-arrow-left me-1"></i> Back to Subscription</a>
                            <button type="submit" class="btn" style="background-color: var(--lavender-vibrant-purple); color: white;"><i class="fas fa-paper-plane me-2"></i>Submit Code</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

<%- include('../../partials/customerFooter') %>
