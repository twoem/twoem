<%- include('../../partials/header', { title: title, customer: customer }) %>
<%- include('../../partials/navbar') %>

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-header bg-warning text-dark">
                    <h3 class="mb-0"><i class="fas fa-key me-2"></i><%= title %></h3>
                </div>
                <div class="card-body">
                    <%# Flash messages are now included globally via header.ejs %>
                    <p class="text-muted">For security reasons, you must change your default password before you can proceed.</p>

                    <form action="/customer/change-password-initial" method="POST">
                        <div class="mb-3">
                            <label for="currentPassword" class="form-label">Current Default Password</label>
                            <input type="password" class="form-control" id="currentPassword" name="currentPassword" value="<%= defaultCustomerPassword %>" readonly>
                            <small class="form-text text-muted">This is the default password assigned to you.</small>
                        </div>
                        <div class="mb-3">
                            <label for="newPassword" class="form-label">New Password</label>
                            <input type="password" class="form-control" id="newPassword" name="newPassword" minlength="<%= passwordMinLength %>" required autofocus>
                            <small class="form-text text-muted">Must be at least <%= passwordMinLength %> characters.</small>
                        </div>
                        <div class="mb-3">
                            <label for="confirmNewPassword" class="form-label">Confirm New Password</label>
                            <input type="password" class="form-control" id="confirmNewPassword" name="confirmNewPassword" minlength="<%= passwordMinLength %>" required>
                        </div>
                        <div class="d-grid">
                            <button type="submit" class="btn btn-primary">
                                <i class="fas fa-save me-1"></i> Set New Password
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<%- include('../../partials/footer') %>
