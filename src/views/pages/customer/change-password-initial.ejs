<%# This page is rendered within layouts/customer_layout.ejs %>
<%# viewData from the controller is available here %>
<% const customer = viewData.customer; %>
<% const defaultCustomerPassword = viewData.defaultCustomerPassword; %>
<% const passwordMinLength = viewData.passwordMinLength; %>
<% const errors = viewData.errors || []; %>

<div class="row justify-content-center pt-4">
    <div class="col-md-7 col-lg-6">
        <div class="card shadow-sm">
            <div class="card-header bg-warning text-dark">
                <h1 class="h5 mb-0"><i class="fas fa-key me-2"></i><%= viewData.title || 'Change Initial Password' %></h1>
            </div>
            <div class="card-body">
                <% if (customer && customer.firstName) { %>
                    <p class="lead">Hello <%= customer.firstName %>,</p>
                <% } %>
                <p class="text-muted">For security reasons, you must change your default password before you can access your customer portal.</p>

                <%- include('../../partials/validation-errors', { errors: errors }) %>
                <%# General flash messages are handled by the layout %>

                <form action="/customer/change-password-initial" method="POST">
                    <div class="mb-3">
                        <label for="currentPassword" class="form-label">Current Default Password</label>
                        <input type="password" class="form-control" id="currentPassword" name="currentPassword" value="<%= defaultCustomerPassword %>" readonly>
                        <small class="form-text text-muted">This is the default password assigned to you.</small>
                    </div>
                    <div class="mb-3">
                        <label for="newPassword" class="form-label">New Password</label>
                        <input type="password" class="form-control <%= errors.find(e => e.param === 'newPassword' || e.msg.toLowerCase().includes('new password')) ? 'is-invalid' : '' %>"
                               id="newPassword" name="newPassword" minlength="<%= passwordMinLength %>" required autofocus>
                        <small class="form-text text-muted">Must be at least <%= passwordMinLength %> characters.</small>
                        <% if (errors.find(e => e.param === 'newPassword' || e.msg.toLowerCase().includes('new password'))) { %>
                            <div class="invalid-feedback">
                                <%= errors.find(e => e.param === 'newPassword' || e.msg.toLowerCase().includes('new password')).msg %>
                            </div>
                        <% } %>
                    </div>
                    <div class="mb-3">
                        <label for="confirmNewPassword" class="form-label">Confirm New Password</label>
                        <input type="password" class="form-control <%= errors.find(e => e.param === 'confirmNewPassword' || e.msg.toLowerCase().includes('passwords do not match')) ? 'is-invalid' : '' %>"
                               id="confirmNewPassword" name="confirmNewPassword" minlength="<%= passwordMinLength %>" required>
                        <% if (errors.find(e => e.param === 'confirmNewPassword' || e.msg.toLowerCase().includes('passwords do not match'))) { %>
                            <div class="invalid-feedback">
                                <%= errors.find(e => e.param === 'confirmNewPassword' || e.msg.toLowerCase().includes('passwords do not match')).msg %>
                            </div>
                        <% } %>
                    </div>
                    <div class="d-grid mt-4">
                        <button type="submit" class="btn btn-primary">
                            <i class="fas fa-save me-2"></i>Set New Password
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
