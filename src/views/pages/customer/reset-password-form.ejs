<%- include('../../partials/header', { title: title, customer: null }) %>
<%- include('../../partials/navbar') %>

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-header bg-info text-white">
                    <h3 class="mb-0"><i class="fas fa-unlock-alt me-2"></i><%= title %></h3>
                </div>
                <div class="card-body">
                    <%# Flash messages are now included globally via header.ejs %>
                    <p class="text-muted">Please enter the OTP sent to your email and set a new password for your account.</p>

                    <form action="/customer/reset-password" method="POST">
                        <input type="hidden" name="urlToken" value="<%= token || '' %>">

                        <div class="mb-3">
                            <label for="phoneNumber" class="form-label">Registered Phone Number</label>
                            <input type="tel" class="form-control" id="phoneNumber" name="phoneNumber" value="<%= phoneNumber || '' %>" placeholder="07... or 01..." pattern="^(0[17])\\d{8}$" title="10 digits, starting with 01 or 07" required>
                        </div>

                        <div class="mb-3">
                            <label for="otp" class="form-label">OTP (One-Time Password)</label>
                            <input type="text" class="form-control" id="otp" name="otp" pattern="\\d{6}" title="6-digit OTP" required autofocus>
                            <small class="form-text text-muted">Check your email for the 6-digit OTP.</small>
                        </div>
                        <div class="mb-3">
                            <label for="newPassword" class="form-label">New Password</label>
                            <input type="password" class="form-control" id="newPassword" name="newPassword" minlength="<%= passwordMinLength %>" required>
                            <small class="form-text text-muted">Must be at least <%= passwordMinLength %> characters.</small>
                        </div>
                        <div class="mb-3">
                            <label for="confirmNewPassword" class="form-label">Confirm New Password</label>
                            <input type="password" class="form-control" id="confirmNewPassword" name="confirmNewPassword" minlength="<%= passwordMinLength %>" required>
                        </div>
                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary">
                                <i class="fas fa-check-circle me-1"></i> Reset Password
                            </button>
                            <a href="/customer/login" class="btn btn-outline-secondary">
                                <i class="fas fa-arrow-left me-1"></i> Back to Login
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<%- include('../../partials/footer') %>
