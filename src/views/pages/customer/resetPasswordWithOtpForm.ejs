<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <link rel="stylesheet" href="/css/style.css">
    <style>
        body {
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            background-color: #f8f9fa; /* Light gray background */
        }
        .reset-password-container {
            background-color: #fff;
            padding: 2rem;
            border-radius: 0.5rem;
            box-shadow: 0 0.5rem 1rem rgba(0,0,0,0.15);
            width: 100%;
            max-width: 480px; /* Slightly wider for more fields */
        }
        .reset-password-container h3 {
            font-weight: 600;
            color: #333;
        }
        .btn-submit {
            background-color: #007bff; /* Bootstrap primary blue */
            border-color: #007bff;
            color: white;
            font-weight: 500;
            padding: 0.75rem;
        }
        .btn-submit:hover {
            background-color: #0056b3;
            border-color: #0056b3;
        }
    </style>
</head>
<body>
    <div class="reset-password-container">
        <div class="text-center mb-4">
            <a href="https://ibb.co/hF8jSC4H"><img src="https://i.ibb.co/XxJgqVKp/IMG-20250701-WA0003.jpg" alt="Twoem Logo" border="0" style="max-height: 70px; margin-bottom: 1rem;"></a>
            <h3>Reset Your Password</h3>
            <p class="text-muted">Enter your account identifier, the OTP sent to your email, and your new password.</p>
        </div>

        <%- include('../../partials/flash-messages') %>

        <form action="/portals/customer/reset-password" method="POST">
            <div class="mb-3">
                <label for="loginIdentifier" class="form-label">Email / Account Number / Phone</label>
                <input type="text" class="form-control" id="loginIdentifier" name="loginIdentifier"
                       value="<%= locals.loginIdentifier || '' %>"
                       placeholder="Enter your email, account number, or phone" required>
            </div>
            <div class="mb-3">
                <label for="otp" class="form-label">OTP (One-Time Password)</label>
                <input type="text" class="form-control" id="otp" name="otp"
                       pattern="\d{6}" title="OTP must be 6 digits."
                       placeholder="Enter the 6-digit OTP" required>
            </div>
            <div class="mb-3">
                <label for="newPassword" class="form-label">New Password</label>
                <input type="password" class="form-control" id="newPassword" name="newPassword"
                       minlength="<%= CUSTOMER_PASSWORD_MIN_LENGTH || 8 %>" required>
                <div class="form-text">
                    Must be at least <%= CUSTOMER_PASSWORD_MIN_LENGTH || 8 %> characters long.
                </div>
            </div>
            <div class="mb-3">
                <label for="confirmNewPassword" class="form-label">Confirm New Password</label>
                <input type="password" class="form-control" id="confirmNewPassword" name="confirmNewPassword" required>
            </div>
            <div class="d-grid">
                <button type="submit" class="btn btn-submit w-100"><i class="fas fa-key me-2"></i>Reset Password & Login</button>
            </div>
        </form>
        <div class="mt-3 text-center">
            <a href="/portals/customer/login">Back to Login</a>
        </div>
         <div class="mt-2 text-center">
            <a href="/portals/customer/forgot-password">Request new OTP?</a>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
