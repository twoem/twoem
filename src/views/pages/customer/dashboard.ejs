<%# This page is rendered within layouts/customer_layout.ejs %>
<%# viewData from the controller is available here %>
<% const profile = viewData.profile; %>
<% const customer = viewData.customer; /* from auth middleware, for name if profile fails */ %>
<% const calculatedDisconnectionDate = viewData.calculatedDisconnectionDate; %>
<% const gracePeriodMessage = viewData.gracePeriodMessage; %>


<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
    <h1 class="h2"><i class="fas fa-tachometer-alt me-2" style="color: #28a745;"></i><%= viewData.title || 'My Dashboard' %></h1>
    <%# Logout is now in the sidebar %>
</div>

<% if (viewData.errorLoading) { %>
    <div class="alert alert-danger" role="alert">
        <h4 class="alert-heading">Error Loading Dashboard!</h4>
        <p>We encountered an issue trying to load your dashboard data. Please try again later or contact support.</p>
        <% if (viewData.errorMessage) { %>
            <p class="mb-0"><small>Details: <%= viewData.errorMessage %></small></p>
        <% } %>
    </div>
<% } else if (profile) { %>
    <div class="row g-4">
        <!-- Customer Profile Card -->
        <div class="col-lg-7 col-md-12 mb-4">
            <div class="card shadow-sm h-100 dashboard-card">
                <div class="card-header" style="background-color: #28a745; color: white;">
                    <h4 class="h5 mb-0"><i class="fas fa-user-circle me-2"></i>
                        Welcome, <%= profile.organisation_name ? profile.organisation_name : profile.first_name %>!
                    </h4>
                </div>
                <div class="card-body">
                    <h5 class="card-title">Account Holder Details</h5>
                    <dl class="row">
                        <dt class="col-sm-4">Name/Org:</dt>
                        <dd class="col-sm-8">
                            <%= profile.organisation_name ? profile.organisation_name : `${profile.first_name} ${profile.second_name || ''} ${profile.last_name}`.trim() %>
                            <% if (profile.organisation_name && profile.first_name) { %>
                                <br><small class="text-muted">(Contact: <%= profile.first_name %> <%= profile.second_name || '' %> <%= profile.last_name %>)</small>
                            <% } %>
                        </dd>
                        <dt class="col-sm-4">Account No:</dt>
                        <dd class="col-sm-8"><%= profile.account_number %></dd>
                        <dt class="col-sm-4">Phone:</dt>
                        <dd class="col-sm-8"><%= profile.phone_number %></dd>
                        <dt class="col-sm-4">Email:</dt>
                        <dd class="col-sm-8"><%= profile.email %></dd>
                        <dt class="col-sm-4">Location:</dt>
                        <dd class="col-sm-8"><%= profile.location %></dd>
                        <dt class="col-sm-4">Installed On:</dt>
                        <dd class="col-sm-8"><%= new Date(profile.installation_date).toLocaleDateString() %></dd>
                    </dl>
                    <hr>
                    <a href="/customer/profile/change-password" class="btn btn-outline-warning btn-sm">
                        <i class="fas fa-key me-1"></i> Change Password
                    </a>
                </div>
            </div>
        </div>

        <!-- Account Summary Card -->
        <div class="col-lg-5 col-md-12 mb-4">
            <div class="card shadow-sm h-100 dashboard-card">
                <div class="card-header" style="background-color: #17a2b8; color: white;">
                     <h4 class="h5 mb-0"><i class="fas fa-file-invoice-dollar me-2"></i>Account Summary</h4>
                </div>
                <div class="card-body">
                    <h5 class="card-title">Current Balance</h5>
                    <h3 class="display-6 <%= profile.current_balance > 0 ? 'text-danger' : (profile.current_balance < 0 ? 'text-success' : 'text-dark') %>">
                        KES <%= profile.current_balance.toFixed(2) %>
                        <% if (profile.current_balance < 0) { %><small class="text-success small">(Credit)</small><% } %>
                        <% if (profile.current_balance > 0) { %><small class="text-danger small">(Due)</small><% } %>
                    </h3>
                    <p class="card-text"><strong>Monthly Subscription:</strong> KES <%= profile.payment_per_month.toFixed(2) %></p>
                    <hr>
                    <h5 class="card-title mt-3">Subscription Status</h5>
                    <% if (profile.is_active) { %>
                        <p class="text-success fw-bold"><i class="fas fa-check-circle me-1"></i> Active</p>
                    <% } else { %>
                        <p class="text-danger fw-bold"><i class="fas fa-times-circle me-1"></i> Inactive / Disconnected</p>
                    <% } %>

                    <% if (gracePeriodMessage) { %>
                        <div class="alert alert-warning small p-2"><%= gracePeriodMessage %></div>
                    <% } %>

                    <% if (calculatedDisconnectionDate || profile.disconnection_date) { %>
                        <p class="text-danger small">
                            <strong>Potential Disconnection:</strong>
                            <%= new Date(calculatedDisconnectionDate || profile.disconnection_date).toLocaleDateString() %>
                        </p>
                    <% } %>
                     <% if (profile.grace_period_ends_at && new Date(profile.grace_period_ends_at) >= new Date() && profile.is_active) { %>
                        <p class="text-warning small">
                            <strong>Grace Period Ends:</strong>
                            <%= new Date(profile.grace_period_ends_at).toLocaleDateString() %>
                        </p>
                    <% } %>

                    <div class="d-grid gap-2 mt-3">
                        <a href="/customer/make-payment" class="btn btn-success">
                            <i class="fas fa-credit-card me-1"></i> Make a Payment
                        </a>
                        <a href="/customer/internet-subscription-status" class="btn btn-info text-white">
                            <i class="fas fa-history me-1"></i> View Payment History
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
<% } else { %>
    <div class="alert alert-warning">Could not load your dashboard information. Please try logging in again or contact support.</div>
<% } %>

<style>
    .dashboard-card {
        border: none;
        border-radius: var(--border-radius-lg);
        transition: transform 0.2s ease-in-out, box-shadow 0.2s ease-in-out;
    }
    .dashboard-card:hover {
        transform: translateY(-5px);
        box-shadow: var(--shadow-lg) !important;
    }
</style>
