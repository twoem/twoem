<% /* This page will be rendered within layouts/portal-customer.ejs */ %>
<% /* Flash messages are handled in the layout */ %>

    <div class="row">
        <div class="col-12">
            <div class="card shadow-lg mb-4" style="border-radius: 0.75rem; background-color: var(--lavender-light-blue);">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <div>
                            <h3 class="mb-0 fw-bold" style="color: var(--lavender-darker-purple);">Welcome Back, <%= customer.firstName %>!</h3>
                            <p class="lead mb-0" style="font-size: 1.1rem;">Your Mynet Customer Portal Dashboard.</p>
                        </div>
                        <div class="text-end">
                            <p class="mb-0 small">
                                <i class="fas fa-calendar-alt me-1"></i> <%= currentDate.toLocaleDateString('en-US', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' }) %>
                            </p>
                            <p class="mb-0 small">
                                <i class="fas fa-clock me-1"></i> <span id="currentTime"></span>
                            </p>
                            <% if (customer.lastLoginAt) { %>
                                <p class="mb-0 small text-muted">
                                    <i class="fas fa-history me-1"></i> Last Login: <%= new Date(customer.lastLoginAt).toLocaleString() %>
                                </p>
                            <% } %>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <!-- Customer Details Card -->
        <div class="col-lg-7 mb-4">
            <div class="card shadow-sm h-100" style="border-radius: 0.75rem; background-color: var(--lavender-lightest-yellow);">
                <div class="card-header" style="background-color: var(--lavender-very-light); border-bottom: 1px solid var(--lavender-light-blue);">
                    <h5 class="mb-0 fw-bold" style="color: var(--lavender-darker-purple);"><i class="fas fa-user-circle me-2"></i>Your Account Details</h5>
                </div>
                <div class="card-body">
                    <dl class="row">
                        <dt class="col-sm-4">Full Name:</dt>
                        <dd class="col-sm-8"><%= customer.firstName %> <%= customer.secondName ? customer.secondName + ' ' : '' %><%= customer.lastName %></dd>

                        <% if (customer.organisationName) { %>
                            <dt class="col-sm-4">Organisation:</dt>
                            <dd class="col-sm-8"><%= customer.organisationName %></dd>
                        <% } %>

                        <dt class="col-sm-4">Account Number:</dt>
                        <dd class="col-sm-8"><strong style="color: var(--lavender-darker-purple);"><%= customer.accountNumber %></strong></dd>

                        <dt class="col-sm-4">Phone Number:</dt>
                        <dd class="col-sm-8"><%= customer.phoneNumber %></dd>

                        <dt class="col-sm-4">Email Address:</dt>
                        <dd class="col-sm-8"><%= customer.email %></dd>

                        <dt class="col-sm-4">Location:</dt>
                        <dd class="col-sm-8"><%= customer.location %></dd>

                        <dt class="col-sm-4">Installation Date:</dt>
                        <dd class="col-sm-8"><%= new Date(customer.installationDate).toLocaleDateString() %></dd>

                        <dt class="col-sm-4">Current Balance:</dt>
                        <dd class="col-sm-8 fw-bold <%= customer.currentBalance < 0 ? 'text-danger' : 'text-success' %>">
                            KES <%= customer.currentBalance ? customer.currentBalance.toFixed(2) : '0.00' %>
                        </dd>

                        <dt class="col-sm-4">Monthly Payment:</dt>
                        <dd class="col-sm-8">KES <%= customer.paymentPerMonth ? customer.paymentPerMonth.toFixed(2) : '0.00' %></dd>

                        <dt class="col-sm-4">Last Payment Date:</dt>
                        <dd class="col-sm-8"><%= lastPaymentDate ? new Date(lastPaymentDate).toLocaleDateString() : 'N/A' %></dd>
                    </dl>
                    <a href="/portals/customer/profile" class="btn btn-sm mt-2" style="background-color: var(--lavender-muted-green); color: white;"><i class="fas fa-edit me-1"></i> Update Profile</a>
                </div>
            </div>
        </div>

        <!-- Right Column: Quick Actions, Summaries, Notifications -->
        <div class="col-lg-5 mb-4">
            <!-- Subscription Overview Card -->
            <div class="card shadow-sm mb-4" style="border-radius: 0.75rem; background-color: var(--lavender-lightest-yellow);">
                <div class="card-header" style="background-color: var(--lavender-very-light); border-bottom: 1px solid var(--lavender-light-blue);">
                    <h5 class="mb-0 fw-bold" style="color: var(--lavender-darker-purple);"><i class="fas fa-wifi me-2"></i>Subscription Overview</h5>
                </div>
                <div class="card-body">
                    <p><strong>Status:</strong> <span class="badge fs-6 <%= customer.isActive && (!customer.disconnectionDate || new Date(customer.disconnectionDate) > new Date()) ? 'bg-success' : 'bg-danger' %>">
                        <%= customer.isActive && (!customer.disconnectionDate || new Date(customer.disconnectionDate) > new Date()) ? 'Active' : 'Disconnected' %>
                    </span></p>
                    <% if (customer.disconnectionDate && customer.isActive) { %>
                        <p class="text-warning fw-bold">Potential Disconnection: <%= new Date(customer.disconnectionDate).toLocaleDateString() %></p>
                    <% } else if (customer.disconnectionDate && !customer.isActive) { %>
                         <p class="text-danger fw-bold">Disconnected On: <%= new Date(customer.disconnectionDate).toLocaleDateString() %></p>
                    <% } %>
                    <a href="/portals/customer/subscription" class="btn d-block mb-2" style="background-color: var(--lavender-light-blue); color: var(--lavender-nav-text);"><i class="fas fa-file-invoice-dollar me-2"></i>View Subscription</a>
                    <a href="/portals/customer/makepayment" class="btn d-block" style="background-color: var(--lavender-vibrant-purple); color: white;"><i class="fas fa-credit-card me-2"></i>Make Payment</a>
                </div>
            </div>

            <!-- Recent Payments Card -->
             <div class="card shadow-sm mb-4" style="border-radius: 0.75rem; background-color: var(--lavender-lightest-yellow);">
                <div class="card-header" style="background-color: var(--lavender-very-light); border-bottom: 1px solid var(--lavender-light-blue);">
                    <h5 class="mb-0 fw-bold" style="color: var(--lavender-darker-purple);"><i class="fas fa-history me-1"></i>Recent Payments</h5>
                </div>
                <ul class="list-group list-group-flush" style="border-radius: 0 0 0.75rem 0.75rem;">
                    <% if (customer.paymentLogs && customer.paymentLogs.length > 0) { %>
                        <% customer.paymentLogs.slice(0, 3).forEach(log => { %>
                            <li class="list-group-item d-flex justify-content-between align-items-center" style="background-color: var(--lavender-lightest-yellow);">
                                <span><%= new Date(log.paymentDate).toLocaleDateString() %> - <%= log.mode %></span>
                                <span class="badge rounded-pill" style="background-color: var(--lavender-muted-green); color: white;">KES <%= log.amount.toFixed(2) %></span>
                            </li>
                        <% }); %>
                    <% } else { %>
                        <li class="list-group-item" style="background-color: var(--lavender-lightest-yellow);">No payment history found.</li>
                    <% } %>
                </ul>
            </div>

            <!-- Notifications Card -->
            <div class="card shadow-sm" style="border-radius: 0.75rem; background-color: var(--lavender-lightest-yellow);">
                <div class="card-header" style="background-color: var(--lavender-very-light); border-bottom: 1px solid var(--lavender-light-blue);">
                    <h5 class="mb-0 fw-bold" style="color: var(--lavender-darker-purple);"><i class="fas fa-bell me-2"></i>Notifications</h5>
                </div>
                <div class="card-body">
                    <% if (notifications && notifications.length > 0) { %>
                        <% notifications.forEach(notification => { %>
                            <div class="alert alert-info" role="alert" style="background-color: var(--lavender-very-light); border-color: var(--lavender-light-blue); color: var(--lavender-nav-text);">
                                <h6 class="alert-heading"><%= notification.title %> <small class="text-muted float-end"><%= new Date(notification.date).toLocaleDateString() %></small></h6>
                                <p><%= notification.message %></p>
                            </div>
                        <% }); %>
                    <% } else { %>
                        <p class="text-muted">No new notifications at the moment.</p>
                    <% } %>
                </div>
            </div>
        </div>
    </div>

<script>
    function updateTime() {
        const timeElement = document.getElementById('currentTime');
        if (timeElement) {
            timeElement.innerText = new Date().toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit', second: '2-digit' });
        }
    }
    setInterval(updateTime, 1000);
    updateTime(); // Initial call
</script>
