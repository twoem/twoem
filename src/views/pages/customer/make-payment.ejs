<%- include('../../partials/header', { title: title, customer: customer }) %>

<div class="container mt-4">
    <%- include('../../partials/flash-messages') %>

    <div class="row">
        <div class="col-md-7 mb-4">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-success text-white">
                    <h3 class="mb-0"><i class="fab fa-paypal me-2"></i><%= title %></h3>
                </div>
                <div class="card-body">
                    <h4>How to Pay via M-Pesa:</h4>
                    <ol class="list-group list-group-numbered mb-4">
                        <li class="list-group-item">Go to M-Pesa menu on your phone (SIM Toolkit, mySafaricom App, or *334#).</li>
                        <li class="list-group-item">Select "Lipa na M-Pesa".</li>
                        <li class="list-group-item">Select "Pay Bill".</li>
                        <li class="list-group-item">
                            Enter Business Number: <strong class="text-primary fs-5"><%= businessNo %></strong>
                        </li>
                        <li class="list-group-item">
                            Enter Account Number: <strong class="text-primary fs-5"><%= accountDetails.account_number %></strong>
                        </li>
                        <li class="list-group-item">Enter the amount you wish to pay.</li>
                        <li class="list-group-item">Enter your M-Pesa PIN and confirm.</li>
                        <li class="list-group-item">You will receive a confirmation SMS from M-Pesa.</li>
                    </ol>

                    <div class="alert alert-info">
                        <i class="fas fa-info-circle me-1"></i>
                        After making the payment, please submit the M-Pesa transaction code/message below so we can verify and update your account promptly.
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-5 mb-4">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0"><i class="fas fa-receipt me-2"></i>Submit Transaction Code</h4>
                </div>
                <div class="card-body">
                     <p>
                        <strong>Account Holder:</strong> <%= accountDetails.first_name %> <%= accountDetails.last_name %><br>
                        <strong>Account Number:</strong> <%= accountDetails.account_number %><br>
                        <strong>Current Balance:</strong>
                        <span class="<%= accountDetails.current_balance > 0 ? 'text-danger fw-bold' : (accountDetails.current_balance < 0 ? 'text-success fw-bold' : '') %>">
                            KES <%= accountDetails.current_balance.toFixed(2) %>
                        </span>
                    </p>
                    <hr>
                    <form action="/customer/submit-payment-code" method="POST">
                        <input type="hidden" name="accountNumber" value="<%= accountDetails.account_number %>">
                        <input type="hidden" name="amountDue" value="<%= accountDetails.current_balance.toFixed(2) %>">

                        <div class="mb-3">
                            <label for="transactionCode" class="form-label">M-Pesa Transaction Code/Message <span class="text-danger">*</span></label>
                            <textarea class="form-control" id="transactionCode" name="transactionCode" rows="3" placeholder="e.g., QWERTY1234 Confirmed. Ksh1500.00 sent to BUSINESS_NO for account YOUR_ACCOUNT_NO..." required></textarea>
                            <small class="form-text text-muted">Please copy the full M-Pesa message or just the code.</small>
                        </div>
                        <div class="d-grid">
                            <button type="submit" class="btn btn-primary">
                                <i class="fas fa-paper-plane me-1"></i> Submit Code for Verification
                            </button>
                        </div>
                    </form>
                </div>
                <div class="card-footer">
                     <a href="/customer/dashboard" class="btn btn-outline-secondary btn-sm">
                        <i class="fas fa-arrow-left me-1"></i> Back to Dashboard
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<%- include('../../partials/footer') %>
