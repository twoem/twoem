<%- include('../../partials/customerHeader', { title: title, customer: customer }) %>

<% /* Main container is opened in customerHeader.ejs and closed in customerFooter.ejs */ %>
    <div class="row justify-content-center">
        <div class="col-lg-10 col-xl-8">
            <div class="card shadow-lg mb-4" style="border-radius: 0.75rem;">
                <div class="card-header text-white" style="background-color: var(--lavender-darker-purple); border-top-left-radius: 0.75rem; border-top-right-radius: 0.75rem;">
                    <h4 class="mb-0"><i class="fas fa-file-invoice-dollar me-2"></i>Internet Subscription Status</h4>
                </div>
                <div class="card-body" style="background-color: var(--lavender-lightest-yellow);">
                    <%- include('../../partials/flash-messages') %>

                    <div class="row mb-4 align-items-center">
                        <div class="col-md-7">
                            <h5 class="fw-bold" style="color: var(--lavender-darker-purple);">Account Summary</h5>
                            <ul class="list-group">
                                <li class="list-group-item d-flex justify-content-between align-items-center">
                                    Current Balance:
                                    <span class="badge bg-<%= customer.currentBalance >= 0 ? 'success' : 'danger' %> rounded-pill fs-6">
                                        KES <%= customer.currentBalance ? customer.currentBalance.toFixed(2) : '0.00' %>
                                    </span>
                                </li>
                                <li class="list-group-item d-flex justify-content-between align-items-center">
                                    Monthly Payment:
                                    <span>KES <%= customer.paymentPerMonth ? customer.paymentPerMonth.toFixed(2) : '0.00' %></span>
                                </li>
                                <li class="list-group-item d-flex justify-content-between align-items-center">
                                    Account Status:
                                    <span class="badge bg-<%= customer.isActive && (!customer.disconnectionDate || new Date(customer.disconnectionDate) > new Date()) ? 'success' : 'danger' %>">
                                        <%= customer.isActive && (!customer.disconnectionDate || new Date(customer.disconnectionDate) > new Date()) ? 'Active' : 'Disconnected/Grace Period' %>
                                    </span>
                                </li>
                                <% if (customer.disconnectionDate) { %>
                                    <li class="list-group-item d-flex justify-content-between align-items-center">
                                        Disconnection Date:
                                        <span class="text-<%= new Date(customer.disconnectionDate) <= new Date() ? 'danger fw-bold' : 'warning' %>">
                                            <%= new Date(customer.disconnectionDate).toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' }) %>
                                            <%
                                                const today = new Date(); today.setHours(0,0,0,0);
                                                const discDate = new Date(customer.disconnectionDate); discDate.setHours(0,0,0,0);
                                                const diffTime = discDate - today;
                                                const diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24));
                                            %>
                                            <% if (diffDays >= 0 && diffDays <= 7 && customer.isActive) { %>
                                                <small class="text-muted">(<%= diffDays %> day<%= diffDays !== 1 ? 's' : '' %> left in grace period)</small>
                                            <% } else if (diffDays < 0 && customer.isActive) { %>
                                                <small class="text-danger">(Overdue)</small>
                                            <% } else if (!customer.isActive) { %>
                                                <small class="text-danger">(Disconnected)</small>
                                            <% } %>
                                        </span>
                                    </li>
                                <% } else if (customer.currentBalance > 0 && customer.isActive) { %>
                                     <li class="list-group-item d-flex justify-content-between align-items-center">
                                        Disconnection Date:
                                        <span class="text-muted">Not applicable (account in credit)</span>
                                     </li>
                                <% } %>
                            </ul>
                        </div>
                        <div class="col-md-5 mt-3 mt-md-0 text-center">
                            <a href="/portal/customer/pay" class="btn btn-lg w-100" style="background-color: var(--lavender-vibrant-purple); color: white; box-shadow: 0 2px 5px rgba(0,0,0,0.2);"><i class="fas fa-credit-card me-2"></i>Make Payment Now</a>
                        </div>
                    </div>

                    <hr style="border-color: var(--lavender-light-blue); border-width: 2px;">

                    <h5 class="fw-bold mt-4" style="color: var(--lavender-darker-purple);"><i class="fas fa-history me-2"></i>Payment Logs</h5>
                    <% if (customer.paymentLogs && customer.paymentLogs.length > 0) { %>
                        <div class="table-responsive">
                            <table class="table table-striped table-hover">
                                <thead>
                                    <tr>
                                        <th>Date</th>
                                        <th>Mode</th>
                                        <th>Amount (KES)</th>
                                        <th>Transaction Code</th>
                                        <th>Approved By</th>
                                        <th>Approval Date</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% customer.paymentLogs.forEach(log => { %>
                                        <tr>
                                            <td><%= new Date(log.paymentDate).toLocaleDateString() %></td>
                                            <td><%= log.mode %></td>
                                            <td><%= log.amount.toFixed(2) %></td>
                                            <td><%= log.transactionCode ? log.transactionCode : '-' %></td>
                                            <td><%= log.approvedBy ? (log.approvedBy.name || 'Admin') : 'Pending' %></td>
                                            <td><%= log.approvalDate ? new Date(log.approvalDate).toLocaleDateString() : '-' %></td>
                                        </tr>
                                    <% }); %>
                                </tbody>
                            </table>
                        </div>
                    <% } else { %>
                        <p class="text-muted p-3">No payment history found.</p>
                    <% } %>
                </div>
                <div class="card-footer text-center" style="background-color: var(--lavender-very-light); border-top: 1px solid var(--lavender-light-blue);">
                     <a href="/portal/customer/dashboard" class="btn btn-sm" style="border-color: var(--lavender-muted-green); color: var(--lavender-muted-green);"><i class="fas fa-arrow-left me-1"></i> Back to Dashboard</a>
                </div>
            </div>
        </div>
    </div>

<%- include('../../partials/customerFooter') %>
