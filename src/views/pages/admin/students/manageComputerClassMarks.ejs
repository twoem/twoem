<%- include('../../../partials/adminHeader', { title: title, admin: admin }) %>

    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/admin/dashboard">Dashboard</a></li>
            <li class="breadcrumb-item"><a href="/admin/students">Manage Students</a></li>
            <li class="breadcrumb-item"><a href="/admin/students/view/<%= student.id %>"><%= student.first_name %> <%= student.surname %></a></li>
            <li class="breadcrumb-item active" aria-current="page">Manage Marks - <%= course.name %></li>
        </ol>
    </nav>

    <h3>Manage Marks: <%= student.first_name %> <%= student.surname %> - <%= course.name %></h3>
    <p>Registration No: <%= student.registration_number %></p>
    <hr>

    <%- include('../../../partials/flash-messages') %><% /* Assuming this partial handles req.flash messages */ %>

    <form action="/admin/enrollments/<%= enrollment.id %>/computer-class-marks" method="POST">
        <h4>Unit Marks (Each out of 100)</h4>
        <div class="row">
            <% const units = [
                { dbCol: 'unit_intro_to_computer_marks', name: 'Introduction to Computer' },
                { dbCol: 'unit_keyboard_mouse_marks', name: 'Keyboard and Mouse Management' },
                { dbCol: 'unit_ms_word_marks', name: 'Ms Word' },
                { dbCol: 'unit_ms_excel_marks', name: 'Ms Excel' },
                { dbCol: 'unit_ms_publisher_marks', name: 'Ms Publisher' },
                { dbCol: 'unit_ms_powerpoint_marks', name: 'Ms PowerPoint' },
                { dbCol: 'unit_ms_access_marks', name: 'Ms Access' },
                { dbCol: 'unit_internet_email_marks', name: 'Internet and Email' }
            ]; %>
            <% units.forEach(unit => { %>
                <div class="col-md-3 mb-3">
                    <label for="<%= unit.dbCol %>" class="form-label"><%= unit.name %></label>
                    <input type="number" class="form-control" id="<%= unit.dbCol %>" name="<%= unit.dbCol %>"
                           value="<%= enrollment[unit.dbCol] !== null && enrollment[unit.dbCol] !== undefined ? enrollment[unit.dbCol] : '' %>"
                           min="0" max="100" placeholder="0-100">
                </div>
            <% }); %>
        </div>

        <h4 class="mt-4">Exam Marks (Each out of 100)</h4>
        <div class="row">
            <% const exams = [
                { dbCol: 'exam_theory_marks', name: 'Theory Exam' },
                { dbCol: 'exam_practical_marks', name: 'Practical Exam' }
            ]; %>
            <% exams.forEach(exam => { %>
                 <div class="col-md-3 mb-3">
                    <label for="<%= exam.dbCol %>" class="form-label"><%= exam.name %></label>
                    <input type="number" class="form-control" id="<%= exam.dbCol %>" name="<%= exam.dbCol %>"
                           value="<%= enrollment[exam.dbCol] !== null && enrollment[exam.dbCol] !== undefined ? enrollment[exam.dbCol] : '' %>"
                           min="0" max="100" placeholder="0-100">
                </div>
            <% }); %>
        </div>

        <hr>
        <div class="mt-3 d-flex justify-content-between">
            <button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> Save All Marks</button>
    </form> <% /* Marks form ends here */ %>

    <form action="/admin/enrollments/<%= enrollment.id %>/finish-course" method="POST" onsubmit="return confirm('Are you sure you want to mark this course as finished for this student? This will calculate the final grade based on current marks.');">
        <button type="submit" class="btn btn-success"><i class="fas fa-check-circle"></i> Finish Course Study</button>
    </form>
        </div>

    <div class="mt-4">
        <h5>Current Calculated Grade (if all marks entered):</h5>
        <%
            let allUnitsEntered = true;
            let unitSum = 0;
            units.forEach(unit => {
                if (enrollment[unit.dbCol] === null || enrollment[unit.dbCol] === undefined) allUnitsEntered = false;
                else unitSum += enrollment[unit.dbCol];
            });

            let allExamsEntered = true;
            let examSum = 0;
            exams.forEach(exam => {
                if (enrollment[exam.dbCol] === null || enrollment[exam.dbCol] === undefined) allExamsEntered = false;
                else examSum += enrollment[exam.dbCol];
            });

            if (allUnitsEntered && allExamsEntered) {
                const unitsContribution = (unitSum / (units.length * 100)) * 30;
                const examsContribution = (examSum / (exams.length * 100)) * 70;
                const finalPercentage = unitsContribution + examsContribution;
        %>
            <p><strong>Units Contribution (30%):</strong> <%= unitsContribution.toFixed(2) %> / 30.00</p>
            <p><strong>Exams Contribution (70%):</strong> <%= examsContribution.toFixed(2) %> / 70.00</p>
            <p class="h5"><strong>Final Percentage: <%= finalPercentage.toFixed(2) %>%</strong></p>
            <p><strong>Status: <%= enrollment.final_grade || 'Not Finalized' %></strong> (Based on saved data)</p>
        <% } else { %>
            <p class="text-muted">Enter all unit and exam marks to calculate final grade.</p>
            <p><strong>Status: <%= enrollment.final_grade || 'Ongoing' %></strong> (Based on saved data)</p>
        <% } %>
    </div>

<%- include('../../../partials/adminFooter') %>
