<%- include('../../../partials/adminHeader', { title: title, admin: admin }) %>

    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/admin/dashboard">Dashboard</a></li>
            <li class="breadcrumb-item"><a href="/admin/students">Manage Students</a></li>
            <li class="breadcrumb-item active" aria-current="page">Edit Student: <%= student ? student.first_name : '...' %> (<%= student ? student.registration_number : '...' %>)</li>
        </ol>
    </nav>

    <h2>Edit Student: <%= student ? student.first_name : 'Details' %></h2>

    <% if (locals.error_msg) { %>
        <div class="alert alert-danger"><%= error_msg %></div>
    <% } %>
    <% if (locals.errors && locals.errors.length > 0) { %>
        <div class="alert alert-danger">
            <ul class="mb-0">
                <% errors.forEach(function(error) { %>
                    <li><%= error.msg || error %></li>
                <% }); %>
            </ul>
        </div>
    <% } %>

    <% if (student) { %>
        <form action="/admin/students/edit/<%= student.id %>" method="POST">
            <div class="row">
                <div class="col-md-6">
                    <fieldset disabled>
                        <div class="mb-3">
                            <label for="registrationNumber" class="form-label">Registration Number</label>
                            <input type="text" class="form-control" id="registrationNumber" name="registrationNumber" value="<%= student.registration_number %>">
                        </div>
                    </fieldset>
                </div>
            </div>
            <div class="row">
                <div class="col-md-6">
                    <div class="mb-3">
                        <label for="firstName" class="form-label">First Name <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="firstName" name="firstName" value="<%= formData.firstName !== undefined ? formData.firstName : student.first_name %>" required>
                    </div>
                </div>
                 <div class="col-md-6">
                    <div class="mb-3">
                        <label for="secondName" class="form-label">Second Name (Optional)</label>
                        <input type="text" class="form-control" id="secondName" name="secondName" value="<%= formData.secondName !== undefined ? formData.secondName : (student.second_name || '') %>">
                    </div>
                </div>
            </div>
            <div class="mb-3">
                <label for="surname" class="form-label">Surname <span class="text-danger">*</span></label>
                <input type="text" class="form-control" id="surname" name="surname" value="<%= formData.surname !== undefined ? formData.surname : student.surname %>" required>
            </div>
            <div class="row">
                <div class="col-md-6">
                    <div class="mb-3">
                        <label for="phoneNumber" class="form-label">Phone Number (07.../01...) <span class="text-danger">*</span></label>
                        <input type="tel" class="form-control" id="phoneNumber" name="phoneNumber" value="<%= formData.phoneNumber !== undefined ? formData.phoneNumber : student.phone_number %>" pattern="^(0[17])\d{8}$" title="Phone number must be 10 digits and start with 01 or 07." required>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="mb-3">
                        <label for="email" class="form-label">Email Address <span class="text-danger">*</span></label>
                        <input type="email" class="form-control" id="email" name="email" value="<%= formData.email !== undefined ? formData.email : student.email %>" required>
                    </div>
                </div>
            </div>
            <div class="row">
                 <div class="col-md-6">
                    <div class="mb-3">
                        <label for="enrolledDate" class="form-label">Enrolled Date <span class="text-danger">*</span></label>
                        <input type="date" class="form-control" id="enrolledDate" name="enrolledDate" value="<%= formData.enrolledDate !== undefined ? formData.enrolledDate : (student.enrolled_date ? new Date(student.enrolled_date).toISOString().split('T')[0] : '') %>" required>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="mb-3">
                        <label for="courseFee" class="form-label">Course Fee (KES) <span class="text-danger">*</span></label>
                        <input type="number" class="form-control" id="courseFee" name="courseFee" value="<%= formData.courseFee !== undefined ? formData.courseFee : student.course_fee %>" min="0" step="any" required>
                    </div>
                </div>
            </div>

            <div class="mb-3 mt-3">
                <p class="form-text">
                    Student Status: <strong><%= student.is_active ? 'Active' : 'Inactive' %></strong>.
                    Password management for students is handled via student-initiated password resets or by specific admin "Reset Student Password" actions (to be implemented).
                </p>
            </div>

            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <button type="submit" class="btn btn-primary">Update Student Details</button>
                    <a href="/admin/students/view/<%= student.id %>" class="btn btn-secondary ms-2">Cancel</a>
                </div>
            </div>
        </form>

        <hr class="my-4">
        <h5>Account Status</h5>
        <form action="/admin/students/toggle-status/<%= student.id %>" method="POST" class="d-inline" onsubmit="return confirm('Are you sure you want to <%= student.is_active ? 'deactivate' : 'activate' %> this student account?');">
            <p>Current status: <strong><%= student.is_active ? 'Active' : 'Inactive' %></strong></p>
            <button type="submit" class="btn <%= student.is_active ? 'btn-warning' : 'btn-success' %>">
                <i class="fas <%= student.is_active ? 'fa-user-slash' : 'fa-user-check' %>"></i>
                <%= student.is_active ? 'Deactivate Student Account' : 'Activate Student Account' %>
            </button>
        </form>

    <% } else { %>
        <div class="alert alert-warning">Student details not found. <a href="/admin/students">Return to student list.</a></div>
    <% } %>

<%- include('../../../partials/adminFooter') %>
