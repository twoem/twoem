<% /* This page is rendered within layouts/portal-admin.ejs */ %>
<% /* Flash messages are handled by the layout */ %>

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="/portals/admin/dashboard">Dashboard</a></li>
        <li class="breadcrumb-item active" aria-current="page">Manage Students</li>
    </ol>
</nav>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Manage Students</h1>
    <a href="/portals/admin/students/register" class="btn btn-primary">
        <i class="fas fa-user-plus me-2"></i>Register New Student
    </a>
</div>

<% if (students && students.length > 0) { %>
    <div class="table-responsive card shadow-sm">
        <table class="table table-striped table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th scope="col">ID</th>
                    <th scope="col">Reg. Number</th>
                    <th scope="col">Full Name</th>
                    <th scope="col">Email</th>
                    <th scope="col">Phone</th>
                    <th scope="col">Status</th>
                    <th scope="col" class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                <% students.forEach(function(student) { %>
                    <tr>
                        <td><%= student.id %></td>
                        <td><%= student.registration_number %></td>
                        <td><%= student.first_name %> <%= student.second_name ? student.second_name + ' ' : '' %><%= student.surname %></td>
                        <td><a href="mailto:<%= student.email %>"><%= student.email %></a></td>
                        <td><%= student.phone_number %></td>
                        <td>
                            <% if (student.is_active) { %>
                                <span class="badge bg-success">Active</span>
                            <% } else { %>
                                <span class="badge bg-danger">Inactive</span>
                            <% } %>
                        </td>
                        <td class="text-end">
                            <div class="btn-group btn-group-sm" role="group">
                                <a href="/portals/admin/students/view/<%= student.id %>" class="btn btn-outline-info" title="View Details">
                                    <i class="fas fa-eye"></i>
                                </a>
                                <a href="/portals/admin/students/edit/<%= student.id %>" class="btn btn-outline-secondary" title="Edit Student">
                                    <i class="fas fa-edit"></i>
                                </a>
                                <!-- Placeholder for future actions like Manage Fees, Manage Academics -->
                                <a href="/portals/admin/students/reset-password/<%= student.id %>" class="btn btn-outline-warning" title="Reset Password" onclick="return confirm('Are you sure you want to reset password for <%= student.first_name %> <%= student.surname %> to the default?');">
                                    <i class="fas fa-key"></i>
                                </a>
                                <form action="/portals/admin/students/toggle-status/<%= student.id %>" method="POST" class="d-inline">
                                    <button type="submit" class="btn <%= student.is_active ? 'btn-outline-danger' : 'btn-outline-success' %>" title="<%= student.is_active ? 'Deactivate' : 'Activate' %> Student" onclick="return confirm('Are you sure you want to <%= student.is_active ? 'deactivate' : 'activate' %> this student account?');">
                                        <i class="fas <%= student.is_active ? 'fa-user-slash' : 'fa-user-check' %>"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                <% }); %>
            </tbody>
        </table>
    </div>
<% } else { %>
    <div class="alert alert-info">No students found. <a href="/portals/admin/students/register">Register the first student.</a></div>
<% } %>
