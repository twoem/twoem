<%- include('../../partials/adminHeader', { title: title, admin: admin }) %>

<% /* Container is opened in adminHeader */ %>
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2><i class="fas fa-users-cog me-2"></i>Manage Internet Customers</h2>
        <a href="/admin/customers/add" class="btn btn-primary"><i class="fas fa-user-plus me-1"></i> Add New Customer</a>
    </div>
    <hr>

    <%- include('../../partials/flash-messages') %>

    <div class="card shadow-sm"> <% /* Global card styles from adminHeader apply */ %>
        <div class="card-header"> <% /* Global card-header styles from adminHeader apply */ %>
            <h5 class="mb-0">Customer List</h5>
        </div>
        <div class="card-body p-0"> <% /* p-0 to make table flush with card */ %>
            <% if (customers && customers.length > 0) { %>
                <div class="table-responsive">
                    <table class="table table-striped table-hover mb-0"> <% /* mb-0 if card-body is p-0 */ %>
                        <thead class="table-light">
                            <tr>
                                <th>Name</th>
                                <th>Account #</th>
                                <th>Email</th>
                                <th>Phone</th>
                                <th>Status</th>
                                <th class="text-end">Balance (KES)</th>
                                <th class="text-end">Monthly (KES)</th>
                                <th class="text-center">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% customers.forEach(customer => { %>
                                <tr>
                                    <td><%= customer.firstName %> <%= customer.lastName %></td>
                                    <td><strong><%= customer.accountNumber %></strong></td>
                                    <td><%= customer.email %></td>
                                    <td><%= customer.phoneNumber %></td>
                                    <td class="text-center">
                                        <span class="badge <%= customer.isActive ? 'bg-success' : 'bg-danger' %>">
                                            <%= customer.isActive ? 'Active' : 'Inactive' %>
                                        </span>
                                    </td>
                                    <td class="text-end fw-bold <%= customer.currentBalance < 0 ? 'text-danger' : 'text-success' %>">
                                        <%= customer.currentBalance ? customer.currentBalance.toFixed(2) : '0.00' %>
                                    </td>
                                    <td class="text-end"><%= customer.paymentPerMonth ? customer.paymentPerMonth.toFixed(2) : '0.00' %></td>
                                    <td class="text-center">
                                        <a href="/admin/customers/<%= customer._id %>/view" class="btn btn-sm btn-outline-info me-1" title="View/Edit Details">
                                            <i class="fas fa-eye"></i> <span class="d-none d-md-inline">View/Edit</span>
                                        </a>
                                        <% /* Payment logging is done on the view/edit page now */ %>
                                    </td>
                                </tr>
                            <% }); %>
                        </tbody>
                    </table>
                </div>
            <% } else { %>
                <div class="alert alert-info m-3">No internet customers found. <a href="/admin/customers/add">Add one now!</a></div>
            <% } %>
        </div>
    </div>

<%- include('../../partials/adminFooter') %>
