<%- include('../../partials/adminHeader') %>

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2><i class="fas fa-users-cog"></i> Manage Internet Customers</h2>
        <a href="/admin/customers/add" class="btn btn-success"><i class="fas fa-user-plus"></i> Add New Customer</a>
    </div>

    <% if (messages && messages.error) { %>
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <%- messages.error %>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    <% } %>
    <% if (messages && messages.success) { %>
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <%- messages.success %>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    <% } %>

    <div class="card shadow-sm">
        <div class="card-header">
            <h5 class="mb-0">Customer List</h5>
        </div>
        <div class="card-body">
            <% if (customers && customers.length > 0) { %>
                <div class="table-responsive">
                    <table class="table table-striped table-hover">
                        <thead>
                            <tr>
                                <th>Name</th>
                                <th>Account #</th>
                                <th>Email</th>
                                <th>Phone</th>
                                <th>Status</th>
                                <th>Balance (KES)</th>
                                <th>Monthly (KES)</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% customers.forEach(customer => { %>
                                <tr>
                                    <td><%= customer.firstName %> <%= customer.lastName %></td>
                                    <td><%= customer.accountNumber %></td>
                                    <td><%= customer.email %></td>
                                    <td><%= customer.phoneNumber %></td>
                                    <td>
                                        <span class="badge bg-<%= customer.isActive ? 'success' : 'danger' %>">
                                            <%= customer.isActive ? 'Active' : 'Inactive' %>
                                        </span>
                                    </td>
                                    <td class="<%= customer.currentBalance < 0 ? 'text-danger fw-bold' : 'text-success' %>">
                                        <%= customer.currentBalance ? customer.currentBalance.toFixed(2) : '0.00' %>
                                    </td>
                                    <td><%= customer.paymentPerMonth ? customer.paymentPerMonth.toFixed(2) : '0.00' %></td>
                                    <td>
                                        <a href="/admin/customers/<%= customer._id %>/view" class="btn btn-sm btn-info" title="View/Edit Details">
                                            <i class="fas fa-eye"></i> View/Edit
                                        </a>
                                        <a href="/admin/customers/<%= customer._id %>/payments" class="btn btn-sm btn-warning ms-1" title="Log Payment">
                                            <i class="fas fa-money-check-alt"></i> Log Payment
                                        </a>
                                        <!-- Add more actions like toggle status if needed -->
                                    </td>
                                </tr>
                            <% }); %>
                        </tbody>
                    </table>
                </div>
            <% } else { %>
                <div class="alert alert-info">No internet customers found. <a href="/admin/customers/add">Add one now!</a></div>
            <% } %>
        </div>
    </div>
</div>

<%- include('../../partials/adminFooter') %>
