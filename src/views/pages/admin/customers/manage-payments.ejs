<%- include('../../../partials/header', { title: title, admin: admin }) %>
<%- include('../../../partials/navbar') %>

<main class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="mb-0"><i class="fas fa-money-bill-wave me-2"></i><%= title %></h2>
        <a href="/admin/customers/view/<%= customer.id %>" class="btn btn-outline-secondary btn-sm">
            <i class="fas fa-arrow-left me-1"></i> Back to Customer Details
        </a>
    </div>

    <%- include('../../../partials/flash-messages') %>

    <!-- Customer Summary -->
    <div class="card shadow-sm mb-4">
        <div class="card-header">
            Customer: <strong><%= customer.first_name %> <%= customer.last_name || customer.organisation_name || '' %></strong> (Acc: <%= customer.account_number %>)
        </div>
        <div class="card-body">
            <p class="card-text"><strong>Current Balance:</strong>
                <span class="fw-bold <%= customer.current_balance > 0 ? 'text-danger' : (customer.current_balance < 0 ? 'text-success' : '') %>">
                    KES <%= customer.current_balance.toFixed(2) %>
                    <% if (customer.current_balance < 0) { %>(Credit)<% } else if (customer.current_balance > 0) { %>(Due)<% } %>
                </span>
            </p>
        </div>
    </div>

    <!-- Log Manual Payment Form -->
    <div class="card shadow-sm mb-4">
        <div class="card-header bg-light">
            <h5 class="mb-0"><i class="fas fa-plus-circle me-2"></i>Log New Manual Payment</h5>
        </div>
        <div class="card-body">
            <form action="/admin/customers/<%= customer.id %>/payments/log-manual" method="POST">
                <div class="row g-3">
                    <div class="col-md-3">
                        <label for="amount" class="form-label">Amount Paid (KES) <span class="text-danger">*</span></label>
                        <input type="number" class="form-control" id="amount" name="amount" step="0.01" min="0.01" required>
                    </div>
                    <div class="col-md-3">
                        <label for="payment_date" class="form-label">Payment Date <span class="text-danger">*</span></label>
                        <input type="date" class="form-control" id="payment_date" name="payment_date" value="<%= new Date().toISOString().split('T')[0] %>" required>
                    </div>
                    <div class="col-md-3">
                        <label for="payment_mode" class="form-label">Payment Mode <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="payment_mode" name="payment_mode" placeholder="e.g., M-Pesa, Cash, Bank" required>
                    </div>
                    <div class="col-md-3">
                        <label for="notes" class="form-label">Notes (Optional)</label>
                        <input type="text" class="form-control" id="notes" name="notes" placeholder="e.g., Receipt No. XYZ">
                    </div>
                    <div class="col-12 text-end">
                        <button type="submit" class="btn btn-primary"><i class="fas fa-save me-1"></i> Log Payment</button>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <!-- Payment History Table -->
    <div class="card shadow-sm">
        <div class="card-header">
            <h5 class="mb-0"><i class="fas fa-history me-2"></i>Payment Logs</h5>
        </div>
        <div class="card-body">
            <% if (paymentLogs && paymentLogs.length > 0) { %>
                <div class="table-responsive">
                    <table class="table table-hover table-striped align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>Log Date</th>
                                <th>Payment Date</th>
                                <th>Mode</th>
                                <th class="text-end">Amount (KES)</th>
                                <th>Transaction Code</th>
                                <th>Status</th>
                                <th>Verified By/At</th>
                                <th>Admin Notes</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% paymentLogs.forEach(log => { %>
                                <tr>
                                    <td><small><%= new Date(log.created_at).toLocaleString() %></small></td>
                                    <td><%= new Date(log.payment_date).toLocaleDateString() %></td>
                                    <td><%= log.payment_mode %></td>
                                    <td class="text-end fw-bold <%= log.amount_paid > 0 ? 'text-success' : 'text-muted' %>">
                                        <%= log.amount_paid.toFixed(2) %>
                                    </td>
                                    <td><%= log.transaction_code || 'N/A' %></td>
                                    <td>
                                        <% if (log.verified_at) { %>
                                            <span class="badge bg-success">Verified</span>
                                        <% } else if (log.payment_mode && log.payment_mode.toLowerCase().includes('pending')) { %>
                                            <span class="badge bg-warning text-dark">Pending Verification</span>
                                        <% } else if (log.amount_paid > 0 && log.verified_by_admin_id) { %>
                                            <span class="badge bg-primary">Manually Logged</span>
                                        <% } else { %>
                                             <span class="badge bg-secondary">Unknown</span>
                                        <% } %>
                                    </td>
                                    <td>
                                        <% if (log.verified_by_admin_id) { %>
                                            Admin: <%= log.verified_by_admin_id %><br>
                                            <small><%= new Date(log.verified_at).toLocaleString() %></small>
                                        <% } else { %>
                                            N/A
                                        <% } %>
                                    </td>
                                    <td><%= log.notes_by_admin || 'N/A' %></td>
                                    <td>
                                        <% if (!log.verified_at && log.payment_mode && log.payment_mode.toLowerCase().includes('pending')) { %>
                                            <button type="button" class="btn btn-success btn-sm" data-bs-toggle="modal" data-bs-target="#verifyPaymentModal-<%= log.id %>">
                                                <i class="fas fa-check-circle me-1"></i> Verify
                                            </button>
                                            <!-- Verify Payment Modal -->
                                            <div class="modal fade" id="verifyPaymentModal-<%= log.id %>" tabindex="-1" aria-labelledby="verifyPaymentModalLabel-<%= log.id %>" aria-hidden="true">
                                                <div class="modal-dialog">
                                                    <div class="modal-content">
                                                        <form action="/admin/customers/<%= customer.id %>/payments/verify/<%= log.id %>" method="POST">
                                                            <div class="modal-header">
                                                                <h5 class="modal-title" id="verifyPaymentModalLabel-<%= log.id %>">Verify Payment</h5>
                                                                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                                            </div>
                                                            <div class="modal-body">
                                                                <p><strong>Customer:</strong> <%= customer.first_name %> <%= customer.last_name %></p>
                                                                <p><strong>Transaction Code:</strong> <%= log.transaction_code %></p>
                                                                <p><strong>Logged Payment Date:</strong> <%= new Date(log.payment_date).toLocaleDateString() %></p>
                                                                <div class="mb-3">
                                                                    <label for="verified_amount_<%= log.id %>" class="form-label">Verified Amount Paid (KES) <span class="text-danger">*</span></label>
                                                                    <input type="number" class="form-control" id="verified_amount_<%= log.id %>" name="verified_amount" step="0.01" min="0.01" required value="<%= customer.payment_per_month %>"> <%# Pre-fill with monthly amount as a guess %>
                                                                </div>
                                                                <p class="text-muted small">Verifying this payment will update the customer's balance.</p>
                                                            </div>
                                                            <div class="modal-footer">
                                                                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                                                                <button type="submit" class="btn btn-success"><i class="fas fa-check-circle me-1"></i>Confirm & Verify</button>
                                                            </div>
                                                        </form>
                                                    </div>
                                                </div>
                                            </div>
                                        <% } else { %>
                                            <span class="text-muted">-</span>
                                        <% } %>
                                    </td>
                                </tr>
                            <% }); %>
                        </tbody>
                    </table>
                </div>
            <% } else { %>
                <div class="alert alert-info text-center">
                    <i class="fas fa-info-circle me-2"></i>No payment logs found for this customer.
                </div>
            <% } %>
        </div>
    </div>
</main>

<%- include('../../../partials/footer') %>
