<%- include('../../partials/header', { title: title, admin: admin }) %>

<div class="container mt-4">
    <div class="card shadow-sm">
        <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
            <h3 class="mb-0"><i class="fas fa-users-cog me-2"></i><%= title %></h3>
            <a href="/admin/customers/register" class="btn btn-light btn-sm">
                <i class="fas fa-user-plus me-1"></i> Register New Customer
            </a>
        </div>
        <div class="card-body">
            <%- include('../../partials/flash-messages') %>

            <% if (customers && customers.length > 0) { %>
                <div class="table-responsive">
                    <table class="table table-hover table-striped align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>#</th>
                                <th>Name / Org</th>
                                <th>Account No.</th>
                                <th>Phone</th>
                                <th>Email</th>
                                <th class="text-end">Balance (KES)</th>
                                <th class="text-center">Status</th>
                                <th class="text-center">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% customers.forEach((customer, index) => { %>
                                <tr>
                                    <td><%= index + 1 %></td>
                                    <td>
                                        <%= customer.organisation_name ? customer.organisation_name : `${customer.first_name} ${customer.last_name}` %>
                                        <% if (customer.organisation_name && (customer.first_name || customer.last_name)) { %>
                                            <br><small class="text-muted">(Contact: <%= customer.first_name %> <%= customer.last_name %>)</small>
                                        <% } %>
                                    </td>
                                    <td><%= customer.account_number %></td>
                                    <td><%= customer.phone_number %></td>
                                    <td><%= customer.email %></td>
                                    <td class="text-end <%= customer.current_balance < 0 ? 'text-success' : (customer.current_balance > 0 ? 'text-danger' : '') %>">
                                        <%= customer.current_balance.toFixed(2) %>
                                    </td>
                                    <td class="text-center">
                                        <% if (customer.is_active) { %>
                                            <span class="badge bg-success">Active</span>
                                        <% } else { %>
                                            <span class="badge bg-danger">Inactive</span>
                                        <% } %>
                                    </td>
                                    <td class="text-center">
                                        <a href="/admin/customers/<%= customer.id %>" class="btn btn-info btn-sm" title="View Details">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                        <a href="/admin/customers/<%= customer.id %>/edit" class="btn btn-warning btn-sm" title="Edit Customer">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                        <a href="/admin/customers/<%= customer.id %>/payments" class="btn btn-success btn-sm" title="Manage Payments">
                                            <i class="fas fa-dollar-sign"></i>
                                        </a>
                                        <!-- Add more actions like toggle status, delete etc. later -->
                                    </td>
                                </tr>
                            <% }); %>
                        </tbody>
                    </table>
                </div>
            <% } else { %>
                <div class="alert alert-info text-center">
                    <i class="fas fa-info-circle me-2"></i>No internet customers found.
                    <a href="/admin/customers/register">Register the first one!</a>
                </div>
            <% } %>
        </div>
    </div>
</div>

<%- include('../../partials/footer') %>
