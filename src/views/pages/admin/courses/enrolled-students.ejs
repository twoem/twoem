<%# This page is rendered within layouts/admin_layout.ejs %>
<%# viewData from the controller is available here directly %>
<% const course = viewData.course; %>
<% const students = viewData.students; %>

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="/admin/dashboard">Admin Dashboard</a></li>
        <li class="breadcrumb-item"><a href="/admin/courses">Manage Courses</a></li>
        <li class="breadcrumb-item active" aria-current="page">
            <%= course ? `Enrolled in ${course.name}` : 'Enrolled Students' %>
        </li>
    </ol>
</nav>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h2">
        <i class="fas fa-users me-2"></i>
        <%= course ? `Students Enrolled in ${course.name}` : 'Enrolled Students' %>
    </h1>
    <%# Maybe a button to enroll more students to this course if needed in future %>
</div>

<% if (viewData.errorLoading) { %>
    <div class="alert alert-danger" role="alert">
        <h4 class="alert-heading">Error Loading Data!</h4>
        <p><%= viewData.errorMessage || "Could not load enrolled students." %></p>
    </div>
<% } else if (students && students.length > 0) { %>
    <div class="card shadow-sm">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-striped table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Reg. No.</th>
                            <th>Full Name</th>
                            <th>Email</th>
                            <th>Enrollment Date</th>
                            <th class="text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% students.forEach(function(studentEnrollment) { %>
                            <tr>
                                <td><%= studentEnrollment.registration_number %></td>
                                <td>
                                    <a href="/admin/students/view/<%= studentEnrollment.student_id %>" class="fw-bold">
                                        <%= studentEnrollment.first_name %> <%= studentEnrollment.second_name || '' %> <%= studentEnrollment.surname || '' %>
                                    </a>
                                </td>
                                <td><a href="mailto:<%= studentEnrollment.email %>"><%= studentEnrollment.email %></a></td>
                                <td><%= new Date(studentEnrollment.enrollment_date).toLocaleDateString() %></td>
                                <td class="text-center">
                                    <a href="/admin/enrollments/<%= studentEnrollment.enrollment_id %>/manage-marks" class="btn btn-sm btn-primary" title="Manage Marks">
                                        <i class="fas fa-edit me-1"></i> Manage Marks
                                    </a>
                                </td>
                            </tr>
                        <% }); %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
<% } else { %>
    <div class="alert alert-info">
        <i class="fas fa-info-circle me-2"></i>No students are currently enrolled in this course.
    </div>
<% } %>
