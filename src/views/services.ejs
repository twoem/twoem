            </div>
        </div>
    </section>

    <!-- Government Services -->
    <section class="bg-white rounded-lg shadow-md p-6 mb-8">
        <h2 class="text-2xl font-semibold mb-6"><%= services.government.title %></h2>
        
        <% services.government.subsections.forEach(subsection => { %>
            <div class="mb-8">
                <div class="flex flex-col md:flex-row gap-6 mb-4">
                    <% if (subsection.image) { %>
                        <div class="md:w-1/3">
                            <img src="<%= subsection.image %>" alt="<%= subsection.title %>" class="w-full rounded-lg">
                        </div>
                    <% } %>
                    <div class="<%= subsection.image ? 'md:w-2/3' : 'w-full' %>">
                        <h3 class="text-xl font-semibold mb-3"><%= subsection.title %></h3>
                        <ul class="grid grid-cols-1 md:grid-cols-2 gap-2 mb-4">
                            <% subsection.items.forEach(item => { %>
                                <li class="flex items-start">
                                    <svg class="h-5 w-5 text-blue-500 mr-2 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                                    </svg>
                                    <%= item %>
                                </li>
                            <% }); %>
