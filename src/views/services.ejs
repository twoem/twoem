<%- include('partials/header', {title: 'Twoem | Services', currentPage: 'services'}) %>

<main class="container mx-auto px-4 py-8">
    <h1 class="text-3xl font-bold mb-8 text-center">Our Services</h1>
    
    <!-- Digital Printing -->
    <section class="bg-white rounded-lg shadow-md p-6 mb-8">
        <div class="flex flex-col md:flex-row gap-6">
            <div class="md:w-1/3">
                <img src="<%= services.printing.image %>" alt="Digital Printing" class="w-full rounded-lg">
            </div>
            <div class="md:w-2/3">
                <h2 class="text-2xl font-semibold mb-4"><%= services.printing.title %></h2>
                <ul class="grid grid-cols-1 md:grid-cols-2 gap-2 mb-6">
                    <% services.printing.items.forEach(item => { %>
                        <li class="flex items-start">
                            <svg class="h-5 w-5 text-green-500 mr-2 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                            </svg>
                            <%= item %>
                        </li>
                    <% }); %>
                </ul>
                <a href="https://wa.me/254707330204?text=<%= services.printing.whatsapp %>" 
                   target="_blank" 
                   class="bg-green-600 text-white px-6 py-3 rounded-lg hover:bg-green-700 inline-flex items-center">
