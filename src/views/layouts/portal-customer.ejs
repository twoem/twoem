<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mynet Customer Portal | <%= title %></title>
    <link rel="icon" href="/favicon.ico" type="image/x-icon">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <link rel="stylesheet" href="/css/style.css"> <!-- Main site style -->
    <style>
        body {
            display: flex;
            flex-direction: column;
            min-height: 100vh;
            background-color: #f4f8fc; /* Light background for portal area */
        }
        .portal-header {
            background-color: #343a40; /* Dark header */
            color: white;
            padding: 0.75rem 1rem;
        }
        .portal-header .navbar-brand img {
            max-height: 40px;
        }
        .portal-header .nav-link {
            color: rgba(255,255,255,.75);
        }
        .portal-header .nav-link:hover,
        .portal-header .nav-link.active {
            color: white;
        }
        .portal-main-content {
            flex-grow: 1;
            padding: 20px;
        }
        .portal-footer {
            /* Standard footer will be included */
        }
        /* Styles from customer/dashboard.ejs for cards, can be globalized or kept specific */
        :root { /* Re-declare color variables if needed, or ensure they are globally available */
            --lavender-lightest-yellow: #FDFBD4; /* Example, adjust to your theme */
            --lavender-muted-green: #BDB96A;
            --lavender-light-blue: #C1BFFF;
            --lavender-very-light: #DBD4FF;
            --lavender-vibrant-purple: #CF6DFC;
            --lavender-darker-purple: #a358d3;
            --lavender-nav-text: #343a40;
        }
        .card {
             border-radius: 0.75rem;
        }
    </style>
</head>
<body>
    <header class="portal-header">
        <nav class="navbar navbar-expand-lg navbar-dark">
            <div class="container-fluid">
                <a class="navbar-brand" href="/portals/customer/dashboard">
                    <img src="https://i.ibb.co/XxJgqVKp/IMG-20250701-WA0003.jpg" alt="Mynet Logo" class="d-inline-block align-text-top">
                    Mynet Portal
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#customerPortalNav" aria-controls="customerPortalNav" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="customerPortalNav">
                    <ul class="navbar-nav ms-auto mb-2 mb-lg-0">
                        <li class="nav-item">
                            <a class="nav-link <%= title === 'Customer Dashboard' ? 'active' : '' %>" href="/portals/customer/dashboard"><i class="fas fa-tachometer-alt me-1"></i>Dashboard</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link <%= title === 'Make Payment' ? 'active' : '' %>" href="/portals/customer/makepayment"><i class="fas fa-credit-card me-1"></i>Make Payment</a>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" id="accountDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                <i class="fas fa-user-cog me-1"></i>Account
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="accountDropdown">
                                <li><a class="dropdown-item" href="/portals/customer/profile">Profile</a></li>
                                <li><a class="dropdown-item" href="/portals/customer/change-password">Change Password</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item" href="/portals/customer/logout">Logout</a></li>
                            </ul>
                        </li>
                    </ul>
                     <% if (typeof customer !== 'undefined' && customer) { %>
                        <span class="navbar-text ms-lg-3">
                            Hello, <%= customer.firstName %>
                        </span>
                    <% } %>
                </div>
            </div>
        </nav>
    </header>

    <main class="portal-main-content container mt-4">
        <%- include('../partials/flash-messages') %>
        <%- body %>
    </main>

    <div class="portal-footer mt-auto">
        <%- include('../partials/footer') %>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
