<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Twoem Student Portal | <%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <link rel="stylesheet" href="/css/style.css"> <!-- Main site style -->
    <style>
        :root { /* Define color variables if not globally available or for override */
            --lavender-lightest-yellow: #FDFBD4;
            --lavender-muted-green: #BDB96A;
            --lavender-light-blue: #C1BFFF;
            --lavender-very-light: #DBD4FF;
            --lavender-vibrant-purple: #CF6DFC;
            --lavender-darker-purple: #a358d3;
        }
        body.portal-minimal-body {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            background-color: var(--lavender-very-light);
            background-image: linear-gradient(135deg, var(--lavender-light-blue) 0%, var(--lavender-very-light) 100%);
            padding: 1rem;
        }
        .minimal-content-wrapper {
            background-color: #ffffff;
            padding: 2rem;
            border-radius: 0.75rem;
            box-shadow: 0 0.5rem 1.5rem rgba(0,0,0,0.1);
            width: 100%;
            max-width: 500px; /* Max width for the content box */
            text-align: center; /* Center logo if placed here */
        }
        .minimal-logo img {
            max-height: 70px;
            margin-bottom: 1.5rem;
        }
        .minimal-footer {
            margin-top: 2rem;
            font-size: 0.9em;
            color: #6c757d;
        }
    </style>
</head>
<body class="portal-minimal-body">
    <div class="minimal-content-wrapper">
        <div class="minimal-logo">
            <a href="/"><img src="https://i.ibb.co/XxJgqVKp/IMG-20250701-WA0003.jpg" alt="Twoem Logo"></a>
        </div>

        <%- body %> <% /* Page specific content will be injected here */ %>

        <div class="minimal-footer">
            <p>&copy; <%= new Date().getFullYear() %> Twoem Online Productions. All Rights Reserved.</p>
            <p><a href="/portals/student/login" class="text-muted">Back to Login</a></p>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
