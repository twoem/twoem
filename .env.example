# General Settings
NODE_ENV=development # 'production' when deployed
PORT=10000
FRONTEND_URL=http://localhost:10000 # Used by some parts of app, e.g. email links
SESSION_SECRET="your_strong_session_secret_here" # For express-session and connect-flash

# Database (SQLite is used by default)
# The path is typically configured in src/config/database.js
# DB_PATH=./db/twoem_online.sqlite
# Example for MongoDB if you were to switch (not current setup):
# DATABASE_URL="mongodb+srv://<user>:<password>@<cluster-url>/?retryWrites=true&w=majority"

# JWT Authentication
JWT_SECRET="your_very_long_and_random_jwt_secret_key_here" # Important: Make this long and random
JWT_EXPIRE="364d" # How long tokens are valid (e.g., 1h, 7d, 365d)
JWT_EXPIRE_MS="31449600000" # JWT_EXPIRE in milliseconds (e.g., 364 * 24 * 60 * 60 * 1000)

# Admin Credentials (Up to 3 admins)
# Generate bcrypt hashes for passwords (e.g., using an online generator or a script like `scripts/hashPassword.js`)
ADMIN1_EMAIL=admin1@example.com
ADMIN1_NAME="Admin User One"
ADMIN1_PASSWORD_HASH="bcrypt_hash_for_admin1_password" # Replace with actual bcrypt hash

ADMIN2_EMAIL=admin2@example.com
ADMIN2_NAME="Admin User Two"
ADMIN2_PASSWORD_HASH="bcrypt_hash_for_admin2_password" # Replace with actual bcrypt hash

ADMIN3_EMAIL=admin3@example.com
ADMIN3_NAME="Admin User Three"
ADMIN3_PASSWORD_HASH="bcrypt_hash_for_admin3_password" # Replace with actual bcrypt hash

# Email Configuration (using Gmail SMTP example, requires "App Password" if 2FA is enabled)
# For production, consider a dedicated transactional email service (SendGrid, Mailgun, AWS SES).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587 # or 465 for SSL
SMTP_SECURE=false # true for port 465 (SSL), false for port 587 (TLS)
SMTP_USER=youremail@gmail.com    # Your sending email address (e.g., Gmail)
SMTP_PASS="your_gmail_app_password" # Gmail App Password if 2FA is enabled, or regular password if not
EMAIL_FROM_NAME="Your Application Name"
EMAIL_FROM="Your Application Name <youremail@gmail.com>" # Must match SMTP_USER or be an authorized sender
CONTACT_RECEIVER_EMAIL=contact_form_recipient@example.com # Where contact form submissions go
REPLY_TO_EMAIL=reply_to@example.com # Default Reply-To for contact form emails

# Student Portal Settings
DEFAULT_STUDENT_PASSWORD=Student@Example2025 # Default password for newly registered students
PASSWORD_MIN_LENGTH=8 # Minimum password length for students

# Customer (Internet Portal) Settings
DEFAULT_CUSTOMER_PASSWORD=Mynet@2020 # Default password for newly registered internet customers
CUSTOMER_PASSWORD_MIN_LENGTH=8 # Minimum password length for customers
JWT_CUSTOMER_EXPIRE=1h # Expiry for customer JWT tokens
JWT_CUSTOMER_EXPIRE_MS=3600000 # Expiry in milliseconds for customer JWT tokens (1h)
ADMIN_EMAIL_RECIPIENT=admin_notifications@example.com # Email for admin to receive payment notifications etc.
BUSINESS_NO=YOUR_MPESA_PAYBILL_NUMBER # M-Pesa Paybill Number

# Academic Settings (Example)
PASSING_GRADE=60 # Percentage

# Debugging (optional)
# DEBUG=true # Example: enables more verbose logging if implemented in the app

# Other API Keys or Service URLs
# SOME_API_KEY=xyz123abc
# ANOTHER_SERVICE_URL=https://api.anotherservice.com/v1
# Ensure any sensitive keys are not committed to version control.
# Use environment variables for all configurable and sensitive data.
