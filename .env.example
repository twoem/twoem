# Server Configuration
PORT=3000
NODE_ENV=development # development or production
SESSION_SECRET=your_very_strong_session_secret_key_here

# JWT Settings
JWT_SECRET=your_jwt_secret_key_here # Should be a long, random string
JWT_EXPIRE=1h # Default expiry for tokens
JWT_EXPIRE_MS=3600000 # Default expiry in milliseconds (1h)

# Admin User Credentials (Example for up to 3 Admins)
# Generate bcrypt hashes for passwords (e.g., using an online generator or script)
ADMIN1_EMAIL=admin1@example.com
ADMIN1_PASSWORD_HASH=PLACEHOLDER_BCRYPT_HASH_FOR_ADMIN1_PASSWORD
ADMIN1_NAME="Admin User One"

ADMIN2_EMAIL=admin2@example.com
ADMIN2_PASSWORD_HASH=PLACEHOLDER_BCRYPT_HASH_FOR_ADMIN2_PASSWORD
ADMIN2_NAME="Admin User Two"

ADMIN3_EMAIL=admin3@example.com
ADMIN3_PASSWORD_HASH=PLACEHOLDER_BCRYPT_HASH_FOR_ADMIN3_PASSWORD
ADMIN3_NAME="Admin User Three"

# Student Portal Settings
DEFAULT_STUDENT_PASSWORD=changeme # Default password for newly registered students
PASSWORD_MIN_LENGTH=8 # Minimum password length for students

# Customer Portal Settings
DEFAULT_CUSTOMER_PASSWORD=Mynet@2020 # Default password for newly registered internet customers
CUSTOMER_PASSWORD_MIN_LENGTH=8 # Minimum password length for customers
JWT_CUSTOMER_EXPIRE=1h # Expiry for customer JWT tokens
JWT_CUSTOMER_EXPIRE_MS=3600000 # Expiry in milliseconds for customer JWT tokens (1h)

# Email Configuration (using Nodemailer with a Gmail example)
# Ensure you have "less secure app access" enabled for Gmail or use an App Password.
# For production, consider a transactional email service (e.g., SendGrid, Mailgun).
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587 # Or 465 if using SSL
MAIL_SECURE=false # true for 465, false for other ports (TLS)
MAIL_USER=your_email@gmail.com
MAIL_PASS=your_email_password_or_app_password
MAIL_FROM_DEFAULT='"Your App Name" <your_email@gmail.com>' # Sender address

# Admin Email for Notifications
ADMIN_EMAIL_RECIPIENT=admin_notifications@example.com # Email address to receive admin notifications (e.g., payment submissions)

# M-Pesa Paybill Information
BUSINESS_NO=YOUR_MPESA_PAYBILL_NUMBER # Business number for M-Pesa payments

# Site Settings (Example)
PASSING_GRADE=60 # Example, if used for student grading

# Database (SQLite) - Path is relative to project root
# DB_PATH=./db/twoem_online.sqlite # Path is usually handled in database.js but can be ENV var

# Add any other environment specific variables here
# Example for API keys if you integrate external services
# SOME_API_KEY=xyz123abc
# ANOTHER_SERVICE_URL=https://api.service.com/v1
